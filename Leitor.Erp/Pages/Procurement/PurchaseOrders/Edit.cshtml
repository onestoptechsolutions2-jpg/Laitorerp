@page
@using Microsoft.AspNetCore.Mvc.Localization
@using Leitor.Erp.Localization
@inject IHtmlLocalizer<ErpResource> L
@model Leitor.Erp.Pages.Procurement.PurchaseOrders.EditModel

<div class="card">
    <div class="card-header">
        <h5 class="card-title mb-0">@L["EditPurchaseOrder"]</h5>
    </div>
    <div class="card-body">
        <form method="post">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="All" class="text-danger"></div>
            <abp-select asp-for="PurchaseOrder.VendorId" asp-items="Model.VendorOptions" label="@L["Vendor"]" />
            <abp-input asp-for="PurchaseOrder.Status" />
            <abp-input asp-for="PurchaseOrder.OrderDate" />
            <abp-input asp-for="PurchaseOrder.ExpectedDeliveryDate" />
            <abp-select asp-for="PurchaseOrder.CurrencyCode" asp-items="Model.CurrencyOptions" label="@L["Currency"]" />
            <abp-input asp-for="PurchaseOrder.Notes" />

            <div class="mt-3">
                <button type="submit" class="btn btn-primary">@L["Save"]</button>
                <a asp-page="./Detail" asp-route-id="@Model.Id" class="btn btn-secondary">@L["Cancel"]</a>
            </div>
        </form>
    </div>
</div>
