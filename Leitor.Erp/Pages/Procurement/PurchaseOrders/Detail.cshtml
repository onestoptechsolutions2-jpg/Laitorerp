@page "{id}"
@using Microsoft.AspNetCore.Mvc.Localization
@using Leitor.Erp.Localization
@inject IHtmlLocalizer<ErpResource> L
@model Leitor.Erp.Pages.Procurement.PurchaseOrders.DetailModel

<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0">@Model.PurchaseOrder.PONumber</h5>
        <div>
            @if (Model.CanEdit)
            {
                <a asp-page="./Edit" asp-route-id="@Model.PurchaseOrder.Id" class="btn btn-outline-primary">@L["Edit"]</a>
            }
            <a asp-page="./Detail" asp-page-handler="Pdf" asp-route-id="@Model.PurchaseOrder.Id" class="btn btn-outline-secondary">@L["DownloadPdf"]</a>
            @if (!string.IsNullOrWhiteSpace(Model.Vendor.Email))
            {
                <form method="post" asp-page-handler="Email" asp-route-id="@Model.PurchaseOrder.Id" class="d-inline" onsubmit="return confirm('@L["EmailToVendor"]?');">
                    <button type="submit" class="btn btn-outline-secondary">@L["EmailToVendor"]</button>
                </form>
            }
            <a asp-page="./Index" class="btn btn-secondary">@L["BackToList"]</a>
        </div>
    </div>
    <div class="card-body">
        <partial name="/Pages/Shared/_PendingDeletionBanner.cshtml" model="Model.HasPendingDeletionRequest" />
        <dl class="row mb-0">
            <dt class="col-sm-2">@L["Vendor"]</dt>
            <dd class="col-sm-4">@Model.PurchaseOrder.VendorName</dd>
            <dt class="col-sm-2">@L["Status"]</dt>
            <dd class="col-sm-4">
                <span class="pill @StatusPill.For(Model.PurchaseOrder.Status)">@L[$"Enum:PurchaseOrderStatus:{(int)Model.PurchaseOrder.Status}"]</span>
                <span class="small text-muted ms-1">(@Model.PurchaseOrder.ReceivedPercent.ToString("N0")% @L["Received"])</span>
            </dd>

            <dt class="col-sm-2">@L["OrderDate"]</dt>
            <dd class="col-sm-4">@Model.PurchaseOrder.OrderDate.ToShortDateString()</dd>
            <dt class="col-sm-2">@L["ExpectedDeliveryDate"]</dt>
            <dd class="col-sm-4">@(Model.PurchaseOrder.ExpectedDeliveryDate?.ToShortDateString())</dd>

            <dt class="col-sm-2">@L["Total"]</dt>
            <dd class="col-sm-4">@Model.PurchaseOrder.Total.ToString("N2")</dd>

            @if (Model.PurchaseOrder.SourceOrderId.HasValue)
            {
                <dt class="col-sm-2">@L["SourceOrder"]</dt>
                <dd class="col-sm-4"><a asp-page="/Sales/Orders/Detail" asp-route-id="@Model.PurchaseOrder.SourceOrderId">@Model.PurchaseOrder.SourceOrderNumber</a></dd>
                <dt class="col-sm-2">@L["ShipToCustomer"]</dt>
                <dd class="col-sm-4">@(Model.PurchaseOrder.ShipToCustomer ? L["Yes"] : L["No"])</dd>
            }

            @if (!string.IsNullOrWhiteSpace(Model.PurchaseOrder.Notes))
            {
                <dt class="col-sm-2">@L["Notes"]</dt>
                <dd class="col-sm-10">@Model.PurchaseOrder.Notes</dd>
            }
        </dl>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h5 class="card-title mb-0">@L["Lines"]</h5>
    </div>
    <div class="card-body">
        @if (Model.CanEdit)
        {
            <form method="post" asp-page-handler="AddLine" class="row g-2 mb-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label">@L["Product"]</label>
                    <select asp-for="NewLine.ProductId" asp-items="Model.ProductOptions" class="form-select"></select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">@L["Description"]</label>
                    <input asp-for="NewLine.Description" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">@L["UnitPrice"]</label>
                    <input asp-for="NewLine.UnitPrice" class="form-control" />
                </div>
                <div class="col-md-1">
                    <label class="form-label">@L["Quantity"]</label>
                    <input asp-for="NewLine.Quantity" class="form-control" />
                </div>
                <div class="col-md-1">
                    <label class="form-label">@L["DiscountPercent"]</label>
                    <input asp-for="NewLine.DiscountPercent" class="form-control" />
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary">@L["AddLine"]</button>
                </div>
            </form>
        }
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>@L["Description"]</th>
                        <th>@L["UnitPrice"]</th>
                        <th>@L["Quantity"]</th>
                        <th>@L["DiscountPercent"]</th>
                        <th>@L["LineTotal"]</th>
                        <th>@L["Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var line in Model.Lines)
                    {
                        <tr>
                            <td>@line.Description</td>
                            <td>@line.UnitPrice.ToString("N2")</td>
                            <td>@line.Quantity</td>
                            <td>@line.DiscountPercent</td>
                            <td>@line.LineTotal.ToString("N2")</td>
                            <td>
                                @if (Model.CanEdit)
                                {
                                    <form method="post" asp-page-handler="DeleteLine" asp-route-lineId="@line.Id" onsubmit="return confirm('@L["AreYouSureToDelete"]');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">@L["Delete"]</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="card mt-3">
    <div class="card-header">
        <h5 class="card-title mb-0">@L["GoodsReceipts"]</h5>
    </div>
    <div class="card-body">
        @if (Model.CanEdit && Model.Lines.Count > 0)
        {
            <form method="post" asp-page-handler="RecordReceipt" class="mb-3">
                <input type="hidden" asp-for="NewReceipt.PurchaseOrderId" />
                <div class="row g-2 mb-2">
                    <div class="col-md-4">
                        <label class="form-label">@L["ReceivedDate"]</label>
                        <input asp-for="NewReceipt.ReceivedDate" type="date" class="form-control" />
                    </div>
                    <div class="col-md-8">
                        <label class="form-label">@L["Notes"]</label>
                        <input asp-for="NewReceipt.Notes" class="form-control" />
                    </div>
                </div>
                <div class="table-responsive mb-2">
                    <table class="table table-sm mb-0">
                        <thead>
                            <tr>
                                <th>@L["Description"]</th>
                                <th>@L["Quantity"]</th>
                                <th>@L["QuantityToReceive"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (var i = 0; i < Model.Lines.Count; i++)
                            {
                                <tr>
                                    <td>@Model.Lines[i].Description</td>
                                    <td>@Model.Lines[i].Quantity</td>
                                    <td>
                                        <input type="hidden" asp-for="NewReceipt.Lines[i].PurchaseOrderLineId" />
                                        <input asp-for="NewReceipt.Lines[i].QuantityReceived" class="form-control form-control-sm" style="max-width: 8rem;" />
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <button type="submit" class="btn btn-primary">@L["RecordReceipt"]</button>
            </form>
            <hr />
        }
        @if (Model.Receipts.Count == 0)
        {
            <p class="text-muted mb-0">@L["NoneYet"]</p>
        }
        else
        {
            @foreach (var receipt in Model.Receipts)
            {
                <div class="mb-2">
                    <strong>@receipt.ReceivedDate.ToShortDateString()</strong>
                    @if (!string.IsNullOrWhiteSpace(receipt.Notes))
                    {
                        <span class="text-muted small">- @receipt.Notes</span>
                    }
                    <ul class="small mb-0">
                        @foreach (var line in receipt.Lines)
                        {
                            <li>@line.PurchaseOrderLineDescription: @line.QuantityReceived.ToString("N2")</li>
                        }
                    </ul>
                </div>
            }
        }
    </div>
</div>

<div class="card mt-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0">@L["SupplierInvoices"]</h5>
        @if (Model.CanEdit)
        {
            <a asp-page="/Procurement/SupplierInvoices/Create" asp-route-purchaseOrderId="@Model.PurchaseOrder.Id" class="btn btn-primary btn-sm">@L["NewSupplierInvoice"]</a>
        }
    </div>
    <div class="card-body">
        @if (Model.SupplierInvoices.Count == 0)
        {
            <p class="text-muted mb-0">@L["NoneYet"]</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>@L["SupplierInvoiceNumber"]</th>
                            <th>@L["PaymentStatus"]</th>
                            <th>@L["Total"]</th>
                            <th>@L["AmountPaid"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var invoice in Model.SupplierInvoices)
                        {
                            <tr>
                                <td><a class="doc-no" asp-page="/Procurement/SupplierInvoices/Detail" asp-route-id="@invoice.Id">@invoice.SupplierInvoiceNumber</a></td>
                                <td><span class="pill @StatusPill.For(invoice.PaymentStatus)">@L[$"Enum:InvoicePaymentStatus:{(int)invoice.PaymentStatus}"]</span></td>
                                <td>@invoice.Total.ToString("N2")</td>
                                <td>@invoice.AmountPaid.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
