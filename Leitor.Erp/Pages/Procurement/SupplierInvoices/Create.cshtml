@page
@using Microsoft.AspNetCore.Mvc.Localization
@using Leitor.Erp.Localization
@inject IHtmlLocalizer<ErpResource> L
@model Leitor.Erp.Pages.Procurement.SupplierInvoices.CreateModel

<div class="card">
    <div class="card-header">
        <h5 class="card-title mb-0">@L["NewSupplierInvoice"] - <span class="doc-no">@Model.PONumber</span></h5>
    </div>
    <div class="card-body">
        <form method="post">
            <input type="hidden" asp-for="PurchaseOrderId" />
            <div asp-validation-summary="All" class="text-danger"></div>
            <abp-input asp-for="SupplierInvoice.SupplierInvoiceNumber" />
            <abp-input asp-for="SupplierInvoice.Status" />
            <abp-input asp-for="SupplierInvoice.IssueDate" />
            <abp-input asp-for="SupplierInvoice.DueDate" />
            <abp-select asp-for="SupplierInvoice.CurrencyCode" asp-items="Model.CurrencyOptions" label="@L["Currency"].Value" />
            <abp-input asp-for="SupplierInvoice.Notes" />

            <p class="text-muted small mt-2">@L["SupplierInvoiceLinesSeeded"]</p>

            <div class="mt-3">
                <button type="submit" class="btn btn-primary">@L["Save"]</button>
                <a asp-page="/Procurement/PurchaseOrders/Detail" asp-route-id="@Model.PurchaseOrderId" class="btn btn-secondary">@L["Cancel"]</a>
            </div>
        </form>
    </div>
</div>
