@page
@using Microsoft.AspNetCore.Mvc.Localization
@using Leitor.Erp.Localization
@inject IHtmlLocalizer<ErpResource> L
@model Leitor.Erp.Pages.Procurement.Vendors.CreateModel

<div class="card">
    <div class="card-header">
        <h5 class="card-title mb-0">@L["NewVendor"]</h5>
    </div>
    <div class="card-body">
        <form method="post">
            <div asp-validation-summary="All" class="text-danger"></div>
            <abp-input asp-for="Vendor.Name" />
            <abp-input asp-for="Vendor.Email" />
            <abp-input asp-for="Vendor.Phone" />
            <abp-input asp-for="Vendor.AddressLine" />
            <abp-input asp-for="Vendor.City" />
            <abp-input asp-for="Vendor.State" />
            <abp-input asp-for="Vendor.PostalCode" />
            <abp-input asp-for="Vendor.Country" />
            <abp-input asp-for="Vendor.Notes" />
            @if (Model.CanUseTaxCompliance)
            {
                <abp-select asp-for="Vendor.WithholdingTaxRateId" asp-items="Model.WithholdingTaxRateOptions" label="@L["WithholdingTaxRate"]" />
            }

            <div class="mt-3">
                <button type="submit" class="btn btn-primary">@L["Save"]</button>
                <a asp-page="./Index" class="btn btn-secondary">@L["Cancel"]</a>
            </div>
        </form>
    </div>
</div>
