@page
@using Microsoft.AspNetCore.Mvc.Localization
@using Leitor.Erp.Localization
@inject IHtmlLocalizer<ErpResource> L
@model Leitor.Erp.Pages.Support.Problems.CreateModel

<div class="card">
    <div class="card-header">
        <h5 class="card-title mb-0">@L["NewProblem"]</h5>
    </div>
    <div class="card-body">
        <form method="post">
            <div asp-validation-summary="All" class="text-danger"></div>
            <abp-input asp-for="Problem.Title" />
            <abp-input asp-for="Problem.Description" />
            <abp-input asp-for="Problem.Status" />
            <abp-input asp-for="Problem.IdentifiedDate" />
            <abp-input asp-for="Problem.RootCause" />
            <abp-input asp-for="Problem.Workaround" />

            <div class="mt-3">
                <button type="submit" class="btn btn-primary">@L["Save"]</button>
                <a asp-page="./Index" class="btn btn-secondary">@L["Cancel"]</a>
            </div>
        </form>
    </div>
</div>
