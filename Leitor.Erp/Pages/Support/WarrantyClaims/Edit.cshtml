@page "{id}"
@using Microsoft.AspNetCore.Mvc.Localization
@using Leitor.Erp.Localization
@inject IHtmlLocalizer<ErpResource> L
@model Leitor.Erp.Pages.Support.WarrantyClaims.EditModel

<div class="card">
    <div class="card-header">
        <h5 class="card-title mb-0">@L["EditWarrantyClaim"]</h5>
    </div>
    <div class="card-body">
        <form method="post">
            <div asp-validation-summary="All" class="text-danger"></div>
            <abp-select asp-for="WarrantyClaim.CustomerId" asp-items="Model.CustomerOptions" label="@L["Customer"].Value" />
            <abp-select asp-for="WarrantyClaim.ContractId" asp-items="Model.ContractOptions" label="@L["Contract"].Value" />
            <abp-select asp-for="WarrantyClaim.JobId" asp-items="Model.JobOptions" label="@L["Job"].Value" />
            <abp-select asp-for="WarrantyClaim.TicketId" asp-items="Model.TicketOptions" label="@L["Tickets"].Value" />
            <abp-input asp-for="WarrantyClaim.Description" />
            <abp-input asp-for="WarrantyClaim.Status" />
            <abp-input asp-for="WarrantyClaim.FiledDate" />

            <div class="mt-3">
                <button type="submit" class="btn btn-primary">@L["Save"]</button>
                <a asp-page="./Detail" asp-route-id="@Model.Id" class="btn btn-secondary">@L["Cancel"]</a>
            </div>
        </form>
    </div>
</div>
