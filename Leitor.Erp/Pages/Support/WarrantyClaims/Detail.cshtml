@page "{id}"
@using Microsoft.AspNetCore.Mvc.Localization
@using Leitor.Erp.Localization
@using Leitor.Erp.Entities.Support
@inject IHtmlLocalizer<ErpResource> L
@model Leitor.Erp.Pages.Support.WarrantyClaims.DetailModel

@{
    var isTerminal = Model.WarrantyClaim.Status is WarrantyClaimStatus.Rejected or WarrantyClaimStatus.Resolved;
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0"><span class="doc-no">@Model.WarrantyClaim.ClaimNumber</span></h5>
        <div>
            @if (Model.CanEdit)
            {
                <a asp-page="./Edit" asp-route-id="@Model.WarrantyClaim.Id" class="btn btn-outline-primary">@L["Edit"]</a>
                @if (!isTerminal)
                {
                    @if (Model.WarrantyClaim.Status != WarrantyClaimStatus.Approved)
                    {
                        <form method="post" asp-page-handler="SetStatus" asp-route-status="1" class="d-inline">
                            <button type="submit" class="btn btn-primary">@L["Enum:WarrantyClaimStatus:1"]</button>
                        </form>
                    }
                    <form method="post" asp-page-handler="SetStatus" asp-route-status="2" class="d-inline" onsubmit="return confirm('@L["AreYouSure"]');">
                        <button type="submit" class="btn btn-outline-danger">@L["Enum:WarrantyClaimStatus:2"]</button>
                    </form>
                    <form method="post" asp-page-handler="SetStatus" asp-route-status="3" class="d-inline">
                        <button type="submit" class="btn btn-success">@L["Enum:WarrantyClaimStatus:3"]</button>
                    </form>
                }
                else
                {
                    <form method="post" asp-page-handler="SetStatus" asp-route-status="0" class="d-inline">
                        <button type="submit" class="btn btn-secondary">@L["Reopen"]</button>
                    </form>
                }
            }
            <a asp-page="./Index" class="btn btn-secondary">@L["BackToList"]</a>
        </div>
    </div>
    <div class="card-body">
        <partial name="/Pages/Shared/_PendingDeletionBanner.cshtml" model="Model.HasPendingDeletionRequest" />
        <dl class="row mb-0">
            <dt class="col-sm-2">@L["Customer"]</dt>
            <dd class="col-sm-4"><a asp-page="/Customers/Detail" asp-route-id="@Model.WarrantyClaim.CustomerId">@Model.WarrantyClaim.CustomerName</a></dd>
            <dt class="col-sm-2">@L["Status"]</dt>
            <dd class="col-sm-4"><span class="pill @StatusPill.For(Model.WarrantyClaim.Status)">@L[$"Enum:WarrantyClaimStatus:{(int)Model.WarrantyClaim.Status}"]</span></dd>

            <dt class="col-sm-2">@L["FiledDate"]</dt>
            <dd class="col-sm-4">@Model.WarrantyClaim.FiledDate.ToShortDateString()</dd>
            <dt class="col-sm-2">@L["ResolvedDate"]</dt>
            <dd class="col-sm-4">@(Model.WarrantyClaim.ResolvedDate?.ToShortDateString())</dd>

            @if (Model.WarrantyClaim.JobId.HasValue)
            {
                <dt class="col-sm-2">@L["Job"]</dt>
                <dd class="col-sm-4"><a asp-page="/FieldService/Jobs/Detail" asp-route-id="@Model.WarrantyClaim.JobId">@L["Job"]</a></dd>
            }
            @if (Model.WarrantyClaim.TicketId.HasValue)
            {
                <dt class="col-sm-2">@L["Tickets"]</dt>
                <dd class="col-sm-4"><a asp-page="/Support/Tickets/Detail" asp-route-id="@Model.WarrantyClaim.TicketId">@L["Tickets"]</a></dd>
            }

            <dt class="col-sm-2">@L["Description"]</dt>
            <dd class="col-sm-10">@Model.WarrantyClaim.Description</dd>
        </dl>
    </div>
</div>
