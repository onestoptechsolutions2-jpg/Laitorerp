@page
@using Microsoft.AspNetCore.Mvc.Localization
@using Leitor.Erp.Localization
@inject IHtmlLocalizer<ErpResource> L
@model Leitor.Erp.Pages.Support.Tickets.CreateModel

<div class="card">
    <div class="card-header">
        <h5 class="card-title mb-0">@L["NewTicket"]</h5>
    </div>
    <div class="card-body">
        <form method="post">
            <div asp-validation-summary="All" class="text-danger"></div>
            <abp-select asp-for="Ticket.CustomerId" asp-items="Model.CustomerOptions" label="@L["Customer"].Value" />
            <abp-select asp-for="Ticket.OrderId" asp-items="Model.OrderOptions" label="@L["Order"].Value" />
            <abp-select asp-for="Ticket.JobId" asp-items="Model.JobOptions" label="@L["Job"].Value" />
            <abp-select asp-for="Ticket.ContractId" asp-items="Model.ContractOptions" label="@L["Contract"].Value" />
            <abp-select asp-for="Ticket.ProblemId" asp-items="Model.ProblemOptions" label="@L["Problem"].Value" />
            <abp-input asp-for="Ticket.Subject" />
            <abp-input asp-for="Ticket.Type" />
            <abp-input asp-for="Ticket.Priority" />
            <abp-select asp-for="Ticket.AssignedToUserId" asp-items="Model.UserOptions" label="@L["AssignedTo"].Value" />

            <div class="mt-3">
                <button type="submit" class="btn btn-primary">@L["Save"]</button>
                <a asp-page="./Index" class="btn btn-secondary">@L["Cancel"]</a>
            </div>
        </form>
    </div>
</div>
