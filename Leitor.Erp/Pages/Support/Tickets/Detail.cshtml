@page "{id}"
@using Microsoft.AspNetCore.Mvc.Localization
@using Leitor.Erp.Localization
@using Leitor.Erp.Entities.Support
@inject IHtmlLocalizer<ErpResource> L
@model Leitor.Erp.Pages.Support.Tickets.DetailModel

@{
    var isTerminal = Model.Ticket.Status is TicketStatus.Resolved or TicketStatus.Closed;
}

<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0"><span class="doc-no">@Model.Ticket.TicketNumber</span> - @Model.Ticket.Subject</h5>
        <div>
            @if (Model.CanEdit)
            {
                <a asp-page="./Edit" asp-route-id="@Model.Ticket.Id" class="btn btn-outline-primary">@L["Edit"]</a>
                @if (!isTerminal)
                {
                    if (Model.Ticket.Status != TicketStatus.InProgress)
                    {
                        <form method="post" asp-page-handler="SetStatus" asp-route-status="1" class="d-inline">
                            <button type="submit" class="btn btn-primary">@L["Enum:TicketStatus:1"]</button>
                        </form>
                    }
                    @if (Model.Ticket.Status != TicketStatus.WaitingOnCustomer)
                    {
                        <form method="post" asp-page-handler="SetStatus" asp-route-status="2" class="d-inline">
                            <button type="submit" class="btn btn-secondary">@L["Enum:TicketStatus:2"]</button>
                        </form>
                    }
                    <form method="post" asp-page-handler="SetStatus" asp-route-status="3" class="d-inline">
                        <button type="submit" class="btn btn-success">@L["Enum:TicketStatus:3"]</button>
                    </form>
                    <form method="post" asp-page-handler="SetStatus" asp-route-status="4" class="d-inline" onsubmit="return confirm('@L["AreYouSure"]');">
                        <button type="submit" class="btn btn-outline-danger">@L["Enum:TicketStatus:4"]</button>
                    </form>
                }
                else
                {
                    <form method="post" asp-page-handler="SetStatus" asp-route-status="0" class="d-inline">
                        <button type="submit" class="btn btn-secondary">@L["Reopen"]</button>
                    </form>
                }
            }
            @if (Model.CanPromoteToKnowledgeBase && isTerminal)
            {
                <a asp-page="/KnowledgeBase/Create" asp-route-SourceTicketId="@Model.Ticket.Id" asp-route-SourceTitle="@Model.Ticket.Subject" class="btn btn-outline-secondary">@L["PromoteToKnowledgeBase"]</a>
            }
            <a asp-page="./Index" class="btn btn-secondary">@L["BackToList"]</a>
        </div>
    </div>
    <div class="card-body">
        <partial name="/Pages/Shared/_PendingDeletionBanner.cshtml" model="Model.HasPendingDeletionRequest" />
        <dl class="row mb-0">
            <dt class="col-sm-2">@L["Customer"]</dt>
            <dd class="col-sm-4">@Model.Ticket.CustomerName</dd>
            <dt class="col-sm-2">@L["AssignedTo"]</dt>
            <dd class="col-sm-4">@Model.Ticket.AssignedToUserName</dd>

            <dt class="col-sm-2">@L["Type"]</dt>
            <dd class="col-sm-4">@L[$"Enum:TicketType:{(int)Model.Ticket.Type}"]</dd>
            <dt class="col-sm-2">@L["Priority"]</dt>
            <dd class="col-sm-4">@L[$"Enum:TicketPriority:{(int)Model.Ticket.Priority}"]</dd>

            <dt class="col-sm-2">@L["Status"]</dt>
            <dd class="col-sm-4"><span class="pill @StatusPill.For(Model.Ticket.Status)">@L[$"Enum:TicketStatus:{(int)Model.Ticket.Status}"]</span></dd>
            <dt class="col-sm-2">@L["ResolvedDate"]</dt>
            <dd class="col-sm-4">@(Model.Ticket.ResolvedDate?.ToString("g"))</dd>

            <dt class="col-sm-2">@L["SlaDueDate"]</dt>
            <dd class="col-sm-4">
                @Model.Ticket.SlaDueDate?.ToString("g")
                @if (Model.Ticket.IsSlaBreached)
                {
                    <span class="pill pill-danger ms-1">@L["SlaBreached"]</span>
                }
            </dd>

            @if (Model.Ticket.CustomerSatisfactionRating.HasValue)
            {
                <dt class="col-sm-2">@L["CustomerSatisfactionRating"]</dt>
                <dd class="col-sm-10">@Model.Ticket.CustomerSatisfactionRating / 5</dd>
            }

            @if (Model.Ticket.ProblemId.HasValue)
            {
                <dt class="col-sm-2">@L["Problem"]</dt>
                <dd class="col-sm-10"><a class="doc-no" asp-page="/Support/Problems/Detail" asp-route-id="@Model.Ticket.ProblemId">@Model.Ticket.ProblemNumber</a></dd>
            }
        </dl>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h5 class="card-title mb-0">@L["Messages"]</h5>
    </div>
    <div class="card-body">
        @if (Model.CanEdit)
        {
            <form method="post" asp-page-handler="AddMessage" class="row g-2 mb-3">
                <div class="col-auto form-check mt-2">
                    <input type="checkbox" asp-for="NewMessage.IsCustomerMessage" class="form-check-input" id="isCustomerMessage" />
                    <label class="form-check-label" for="isCustomerMessage">@L["IsCustomerMessage"]</label>
                </div>
                <div class="col">
                    <input type="text" asp-for="NewMessage.Text" class="form-control" placeholder="@L["MessageText"]" />
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-primary">@L["AddMessage"]</button>
                </div>
            </form>
        }

        @foreach (var message in Model.Messages)
        {
            <div class="border-bottom pb-2 mb-2">
                <div class="d-flex justify-content-between">
                    <div>
                        @if (message.IsCustomerMessage)
                        {
                            <span class="badge bg-info">@L["IsCustomerMessage"]</span>
                        }
                        <strong class="ms-2">@message.CreatorUserName</strong>
                        <span class="text-muted ms-2">@message.CreationTime.ToString("g")</span>
                    </div>
                    @if (Model.CanEdit)
                    {
                        <form method="post" asp-page-handler="DeleteMessage" asp-route-messageId="@message.Id" onsubmit="return confirm('@L["AreYouSureToDelete"]');">
                            <button type="submit" class="btn btn-sm btn-outline-danger">@L["Delete"]</button>
                        </form>
                    }
                </div>
                <div>@message.Text</div>
            </div>
        }
    </div>
</div>
