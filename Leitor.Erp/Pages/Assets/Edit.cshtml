@page
@using Microsoft.AspNetCore.Mvc.Localization
@using Leitor.Erp.Localization
@inject IHtmlLocalizer<ErpResource> L
@model Leitor.Erp.Pages.Assets.EditModel

<div class="card">
    <div class="card-header">
        <h5 class="card-title mb-0">@L["EditAsset"]</h5>
    </div>
    <div class="card-body">
        <form method="post">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="All" class="text-danger"></div>
            <abp-input asp-for="Item.Name" />
            <abp-input asp-for="Item.CIType" />
            <abp-select asp-for="Item.CustomerId" asp-items="Model.CustomerOptions" label="@L["Customer"].Value" />
            <abp-input asp-for="Item.SerialNumber" />
            <abp-input asp-for="Item.Status" />
            <abp-input asp-for="Item.PurchaseDate" />
            <abp-input asp-for="Item.WarrantyExpiryDate" />
            <abp-input asp-for="Item.Notes" />

            <div class="mt-3">
                <button type="submit" class="btn btn-primary">@L["Save"]</button>
                <a asp-page="./Detail" asp-route-id="@Model.Id" class="btn btn-secondary">@L["Cancel"]</a>
            </div>
        </form>
    </div>
</div>
