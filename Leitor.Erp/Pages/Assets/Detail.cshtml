@page "{id}"
@using Microsoft.AspNetCore.Mvc.Localization
@using Leitor.Erp.Localization
@inject IHtmlLocalizer<ErpResource> L
@model Leitor.Erp.Pages.Assets.DetailModel

<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0">@Model.Item.Name</h5>
        <div>
            @if (Model.CanEdit)
            {
                <a asp-page="./Edit" asp-route-id="@Model.Item.Id" class="btn btn-outline-primary">@L["Edit"]</a>
            }
            <a asp-page="./Index" class="btn btn-secondary">@L["BackToList"]</a>
        </div>
    </div>
    <div class="card-body">
        <partial name="/Pages/Shared/_PendingDeletionBanner.cshtml" model="Model.HasPendingDeletionRequest" />
        <dl class="row mb-0">
            <dt class="col-sm-2">@L["CIType"]</dt>
            <dd class="col-sm-4">@L[$"Enum:ConfigurationItemType:{(int)Model.Item.CIType}"]</dd>
            <dt class="col-sm-2">@L["Status"]</dt>
            <dd class="col-sm-4"><span class="pill @StatusPill.For(Model.Item.Status)">@L[$"Enum:ConfigurationItemStatus:{(int)Model.Item.Status}"]</span></dd>

            @if (!string.IsNullOrWhiteSpace(Model.Item.CustomerName))
            {
                <dt class="col-sm-2">@L["Customer"]</dt>
                <dd class="col-sm-4"><a asp-page="/Customers/Detail" asp-route-id="@Model.Item.CustomerId">@Model.Item.CustomerName</a></dd>
            }
            @if (!string.IsNullOrWhiteSpace(Model.Item.SerialNumber))
            {
                <dt class="col-sm-2">@L["SerialNumber"]</dt>
                <dd class="col-sm-4">@Model.Item.SerialNumber</dd>
            }

            @if (Model.Item.PurchaseDate.HasValue)
            {
                <dt class="col-sm-2">@L["PurchaseDate"]</dt>
                <dd class="col-sm-4">@Model.Item.PurchaseDate.Value.ToShortDateString()</dd>
            }
            @if (Model.Item.WarrantyExpiryDate.HasValue)
            {
                <dt class="col-sm-2">@L["WarrantyExpiryDate"]</dt>
                <dd class="col-sm-4">@Model.Item.WarrantyExpiryDate.Value.ToShortDateString()</dd>
            }

            @if (!string.IsNullOrWhiteSpace(Model.Item.Notes))
            {
                <dt class="col-sm-2">@L["Notes"]</dt>
                <dd class="col-sm-10">@Model.Item.Notes</dd>
            }
        </dl>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h5 class="card-title mb-0">@L["Relationships"]</h5>
    </div>
    <div class="card-body">
        @if (Model.CanEdit)
        {
            <form method="post" asp-page-handler="AddRelationship" class="row g-2 mb-3 align-items-end">
                <div class="col-md-5">
                    <label class="form-label">@L["ConfigurationItem"]</label>
                    <select asp-for="NewRelationship.TargetCiId" asp-items="Model.TargetCiOptions" class="form-select">
                        <option value="">@L["Select"]</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">@L["RelationshipType"]</label>
                    <select asp-for="NewRelationship.RelationshipType" class="form-select">
                        <option value="0">@L["Enum:ConfigurationItemRelationshipType:0"]</option>
                        <option value="1">@L["Enum:ConfigurationItemRelationshipType:1"]</option>
                        <option value="2">@L["Enum:ConfigurationItemRelationshipType:2"]</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary">@L["AddRelationship"]</button>
                </div>
            </form>
        }
        <div class="table-responsive">
            <table class="table table-sm mb-0">
                <thead>
                    <tr><th>@L["RelationshipType"]</th><th>@L["ConfigurationItem"]</th><th>@L["Actions"]</th></tr>
                </thead>
                <tbody>
                    @if (!Model.Relationships.Any())
                    {
                        <tr class="table-empty-state"><td colspan="3">@L["NoResultsFound"]</td></tr>
                    }
                    @foreach (var relationship in Model.Relationships)
                    {
                        <tr>
                            <td>@L[$"Enum:ConfigurationItemRelationshipType:{(int)relationship.RelationshipType}"]</td>
                            <td><a asp-page="./Detail" asp-route-id="@relationship.TargetCiId">@relationship.TargetCiName</a></td>
                            <td>
                                @if (Model.CanEdit)
                                {
                                    <form method="post" asp-page-handler="DeleteRelationship" asp-route-relationshipId="@relationship.Id" class="d-inline" onsubmit="return confirm('@L["AreYouSureToDelete"]');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">@L["Delete"]</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
