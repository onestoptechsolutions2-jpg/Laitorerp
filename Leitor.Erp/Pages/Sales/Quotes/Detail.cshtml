@page "{id}"
@using Microsoft.AspNetCore.Mvc.Localization
@using Leitor.Erp.Localization
@inject IHtmlLocalizer<ErpResource> L
@model Leitor.Erp.Pages.Sales.Quotes.DetailModel

<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0">@Model.Quote.QuoteNumber - @Model.Quote.Title</h5>
        <div>
            @if (Model.CanEdit)
            {
                <a asp-page="./Edit" asp-route-id="@Model.Quote.Id" class="btn btn-outline-primary">@L["Edit"]</a>
                <form method="post" asp-page-handler="ConvertToOrder" class="d-inline" onsubmit="return confirm('@L["ConvertToOrder"]?');">
                    <button type="submit" class="btn btn-success">@L["ConvertToOrder"]</button>
                </form>
            }
            <a asp-page="./Index" class="btn btn-secondary">@L["BackToList"]</a>
        </div>
    </div>
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-2">@L["Customer"]</dt>
            <dd class="col-sm-4">@Model.Quote.CustomerName</dd>
            <dt class="col-sm-2">@L["Status"]</dt>
            <dd class="col-sm-4">@L[$"Enum:QuoteStatus:{(int)Model.Quote.Status}"]</dd>

            <dt class="col-sm-2">@L["IssueDate"]</dt>
            <dd class="col-sm-4">@Model.Quote.IssueDate.ToShortDateString()</dd>
            <dt class="col-sm-2">@L["ExpiryDate"]</dt>
            <dd class="col-sm-4">@(Model.Quote.ExpiryDate?.ToShortDateString())</dd>

            <dt class="col-sm-2">@L["Total"]</dt>
            <dd class="col-sm-10">@Model.Quote.Total.ToString("N2")</dd>

            @if (!string.IsNullOrWhiteSpace(Model.Quote.Notes))
            {
                <dt class="col-sm-2">@L["Notes"]</dt>
                <dd class="col-sm-10">@Model.Quote.Notes</dd>
            }
        </dl>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h5 class="card-title mb-0">@L["Lines"]</h5>
    </div>
    <div class="card-body">
        @if (Model.CanEdit)
        {
            <form method="post" asp-page-handler="AddLine" class="row g-2 mb-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label">@L["Product"]</label>
                    <select asp-for="NewLine.ProductId" asp-items="Model.ProductOptions" class="form-select"></select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">@L["Description"]</label>
                    <input asp-for="NewLine.Description" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">@L["UnitPrice"]</label>
                    <input asp-for="NewLine.UnitPrice" class="form-control" />
                </div>
                <div class="col-md-1">
                    <label class="form-label">@L["Quantity"]</label>
                    <input asp-for="NewLine.Quantity" class="form-control" />
                </div>
                <div class="col-md-1">
                    <label class="form-label">@L["DiscountPercent"]</label>
                    <input asp-for="NewLine.DiscountPercent" class="form-control" />
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary">@L["AddLine"]</button>
                </div>
            </form>
        }
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>@L["Description"]</th>
                        <th>@L["UnitPrice"]</th>
                        <th>@L["Quantity"]</th>
                        <th>@L["DiscountPercent"]</th>
                        <th>@L["LineTotal"]</th>
                        <th>@L["Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var line in Model.Lines)
                    {
                        <tr>
                            <td>@line.Description</td>
                            <td>@line.UnitPrice.ToString("N2")</td>
                            <td>@line.Quantity</td>
                            <td>@line.DiscountPercent</td>
                            <td>@line.LineTotal.ToString("N2")</td>
                            <td>
                                @if (Model.CanEdit)
                                {
                                    <form method="post" asp-page-handler="DeleteLine" asp-route-lineId="@line.Id" onsubmit="return confirm('@L["AreYouSureToDelete"]');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">@L["Delete"]</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
