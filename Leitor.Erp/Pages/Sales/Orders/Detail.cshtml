@page "{id}"
@using Microsoft.AspNetCore.Mvc.Localization
@using Leitor.Erp.Localization
@using Leitor.Erp.Entities.Sales
@inject IHtmlLocalizer<ErpResource> L
@model Leitor.Erp.Pages.Sales.Orders.DetailModel

<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0"><span class="doc-no">@Model.Order.OrderNumber</span></h5>
        <div>
            @if (Model.CanEdit)
            {
                <a asp-page="./Edit" asp-route-id="@Model.Order.Id" class="btn btn-outline-primary">@L["Edit"]</a>
                @if (Model.CanIssueFinalInvoice)
                {
                    <form method="post" asp-page-handler="IssueFinalInvoice" class="d-inline" onsubmit="return confirm('@L["IssueFinalInvoice"]?');">
                        <button type="submit" class="btn btn-success">@L["IssueFinalInvoice"]</button>
                    </form>
                }
                <a asp-page="/Procurement/PurchaseOrders/CreateFromOrder" asp-route-orderId="@Model.Order.Id" class="btn btn-outline-primary">@L["CreatePurchaseOrder"]</a>
            }
            <a asp-page="./Detail" asp-page-handler="Pdf" asp-route-id="@Model.Order.Id" class="btn btn-outline-secondary">@L["DownloadPdf"]</a>
            @if (!string.IsNullOrWhiteSpace(Model.Customer.Email))
            {
                <form method="post" asp-page-handler="Email" asp-route-id="@Model.Order.Id" class="d-inline" onsubmit="return confirm('@L["EmailToCustomer"]?');">
                    <button type="submit" class="btn btn-outline-secondary">@L["EmailToCustomer"]</button>
                </form>
            }
            <a asp-page="./Index" class="btn btn-secondary">@L["BackToList"]</a>
        </div>
    </div>
    <div class="card-body">
        <partial name="/Pages/Shared/_PendingDeletionBanner.cshtml" model="Model.HasPendingDeletionRequest" />
        <dl class="row mb-0">
            <dt class="col-sm-2">@L["Customer"]</dt>
            <dd class="col-sm-4">@Model.Order.CustomerName</dd>
            <dt class="col-sm-2">@L["Status"]</dt>
            <dd class="col-sm-4"><span class="pill @StatusPill.For(Model.Order.Status)">@L[$"Enum:OrderStatus:{(int)Model.Order.Status}"]</span></dd>

            <dt class="col-sm-2">@L["OrderDate"]</dt>
            <dd class="col-sm-4">@Model.Order.OrderDate.ToShortDateString()</dd>
            <dt class="col-sm-2">@L["PaymentTerms"]</dt>
            <dd class="col-sm-4">@L[$"Enum:PaymentTerms:{(int)Model.Order.PaymentTerms}"]</dd>

            @if (!string.IsNullOrWhiteSpace(Model.Order.QuoteNumber))
            {
                <dt class="col-sm-2">@L["FromQuote"]</dt>
                <dd class="col-sm-10"><span class="doc-no">@Model.Order.QuoteNumber</span></dd>
            }

            <dt class="col-sm-2">@L["Subtotal"]</dt>
            <dd class="col-sm-4">@Model.Order.Subtotal.ToString("N2")</dd>
            <dt class="col-sm-2">@L["Tax"]</dt>
            <dd class="col-sm-4">@Model.Order.TaxAmount.ToString("N2")</dd>

            <dt class="col-sm-2">@L["Total"]</dt>
            <dd class="col-sm-4">@Model.Order.Total.ToString("N2") @Model.Order.CurrencyCode</dd>

            @if (!string.IsNullOrWhiteSpace(Model.Order.Notes))
            {
                <dt class="col-sm-2">@L["Notes"]</dt>
                <dd class="col-sm-10">@Model.Order.Notes</dd>
            }
        </dl>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h5 class="card-title mb-0">@L["Lines"]</h5>
    </div>
    <div class="card-body">
        @if (Model.CanEdit)
        {
            <form method="post" asp-page-handler="AddLine" class="row g-2 mb-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label">@L["Product"]</label>
                    <select asp-for="NewLine.ProductId" asp-items="Model.ProductOptions" class="form-select"></select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">@L["Description"]</label>
                    <input asp-for="NewLine.Description" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">@L["UnitPrice"]</label>
                    <input asp-for="NewLine.UnitPrice" class="form-control" />
                </div>
                <div class="col-md-1">
                    <label class="form-label">@L["Quantity"]</label>
                    <input asp-for="NewLine.Quantity" class="form-control" />
                </div>
                <div class="col-md-1">
                    <label class="form-label">@L["DiscountPercent"]</label>
                    <input asp-for="NewLine.DiscountPercent" class="form-control" />
                </div>
                <div class="col-md-1">
                    <label class="form-label">@L["Cost"]</label>
                    <input asp-for="NewLine.Cost" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">@L["TaxRate"]</label>
                    <select asp-for="NewLine.TaxRateId" asp-items="Model.TaxRateOptions" class="form-select"></select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary">@L["AddLine"]</button>
                </div>
            </form>
        }
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>@L["Description"]</th>
                        <th>@L["UnitPrice"]</th>
                        <th>@L["Quantity"]</th>
                        <th>@L["DiscountPercent"]</th>
                        <th>@L["Tax"]</th>
                        <th>@L["Margin"]</th>
                        <th>@L["LineTotal"]</th>
                        <th>@L["Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var line in Model.Lines)
                    {
                        <tr>
                            <td>@line.Description</td>
                            <td>@line.UnitPrice.ToString("N2")</td>
                            <td>@line.Quantity</td>
                            <td>@line.DiscountPercent</td>
                            <td>@line.TaxRatePercent.ToString("N0")%</td>
                            <td>@(line.MarginPercent.HasValue ? $"{line.MarginPercent:N1}%" : "-")</td>
                            <td>@line.LineTotal.ToString("N2")</td>
                            <td>
                                @if (Model.CanEdit)
                                {
                                    <form method="post" asp-page-handler="DeleteLine" asp-route-lineId="@line.Id" onsubmit="return confirm('@L["AreYouSureToDelete"]');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">@L["Delete"]</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="card mt-3">
    <div class="card-header">
        <h5 class="card-title mb-0">@L["PurchaseOrders"]</h5>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>@L["PONumber"]</th>
                        <th>@L["Vendor"]</th>
                        <th>@L["Status"]</th>
                        <th>@L["ShipToCustomer"]</th>
                        <th>@L["Total"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var purchaseOrder in Model.PurchaseOrders)
                    {
                        <tr>
                            <td><a class="doc-no" asp-page="/Procurement/PurchaseOrders/Detail" asp-route-id="@purchaseOrder.Id">@purchaseOrder.PONumber</a></td>
                            <td>@purchaseOrder.VendorName</td>
                            <td><span class="pill @StatusPill.For(purchaseOrder.Status)">@L[$"Enum:PurchaseOrderStatus:{(int)purchaseOrder.Status}"]</span></td>
                            <td>@(purchaseOrder.ShipToCustomer ? L["Yes"] : L["No"])</td>
                            <td>@purchaseOrder.Total.ToString("N2") @purchaseOrder.CurrencyCode</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (Model.Order.PaymentTerms == PaymentTerms.Milestone)
{
    <div class="card mt-3">
        <div class="card-header">
            <h5 class="card-title mb-0">@L["PaymentMilestones"]</h5>
        </div>
        <div class="card-body">
            @if (Model.CanEdit)
            {
                <form method="post" asp-page-handler="AddMilestone" class="row g-2 mb-3 align-items-end">
                    <div class="col-md-4">
                        <label class="form-label">@L["Description"]</label>
                        <input asp-for="NewMilestone.Description" class="form-control" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">@L["Percent"]</label>
                        <input asp-for="NewMilestone.Percent" class="form-control" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">@L["Kind"]</label>
                        <select asp-for="NewMilestone.Kind" class="form-select">
                            <option value="0">@L["Enum:OrderPaymentMilestoneKind:0"]</option>
                            <option value="1">@L["Enum:OrderPaymentMilestoneKind:1"]</option>
                            <option value="2">@L["Enum:OrderPaymentMilestoneKind:2"]</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <button type="submit" class="btn btn-primary">@L["AddMilestone"]</button>
                    </div>
                </form>
            }
            <div class="table-responsive">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>@L["Description"]</th>
                            <th>@L["Percent"]</th>
                            <th>@L["Kind"]</th>
                            <th>@L["Amount"]</th>
                            <th>@L["Status"]</th>
                            <th>@L["Actions"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var milestone in Model.Milestones)
                        {
                            <tr>
                                <td>@milestone.Description</td>
                                <td>@milestone.Percent.ToString("N0")%</td>
                                <td>@L[$"Enum:OrderPaymentMilestoneKind:{(int)milestone.Kind}"]</td>
                                <td>@((Model.Order.Subtotal * milestone.Percent / 100m).ToString("N2"))</td>
                                <td>@(milestone.IsInvoiced ? L["Invoiced"] : L["NotInvoiced"])</td>
                                <td>
                                    @if (Model.CanEdit && !milestone.IsInvoiced)
                                    {
                                        <form method="post" asp-page-handler="InvoiceMilestone" asp-route-milestoneId="@milestone.Id" class="d-inline" onsubmit="return confirm('@L["ConvertToInvoice"]?');">
                                            <button type="submit" class="btn btn-sm btn-success">@L["ConvertToInvoice"]</button>
                                        </form>
                                        <form method="post" asp-page-handler="DeleteMilestone" asp-route-milestoneId="@milestone.Id" class="d-inline" onsubmit="return confirm('@L["AreYouSureToDelete"]');">
                                            <button type="submit" class="btn btn-sm btn-outline-danger">@L["Delete"]</button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

<div class="card mt-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0">@L["FieldServiceJobsForOrder"]</h5>
        @if (Model.CanEdit)
        {
            <a asp-page="/FieldService/Jobs/Create" asp-route-orderId="@Model.Order.Id" class="btn btn-primary btn-sm">@L["ScheduleInstallation"]</a>
        }
    </div>
    <div class="card-body">
        @if (Model.Jobs.Count == 0)
        {
            <p class="text-muted mb-0">@L["NoResultsFound"]</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>@L["ScheduledDate"]</th>
                            <th>@L["Type"]</th>
                            <th>@L["Status"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var job in Model.Jobs)
                        {
                            <tr>
                                <td><a asp-page="/FieldService/Jobs/Detail" asp-route-id="@job.Id">@job.ScheduledDate.ToShortDateString()</a></td>
                                <td>@L[$"Enum:FieldServiceJobType:{(int)job.Type}"]</td>
                                <td><span class="pill @StatusPill.For(job.Status)">@L[$"Enum:FieldServiceJobStatus:{(int)job.Status}"]</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
