@page
@using Microsoft.AspNetCore.Mvc.Localization
@using Leitor.Erp.Localization
@inject IHtmlLocalizer<ErpResource> L
@model Leitor.Erp.Pages.Sales.Orders.EditModel

@{
    var isLockedAndNotUnlocked = Model.OrderDetails.IsLocked && Model.OrderDetails.UnlockedByUserId == null;
}

<div class="card">
    <div class="card-header">
        <h5 class="card-title mb-0">@L["EditOrder"]</h5>
    </div>
    <div class="card-body">
        @if (isLockedAndNotUnlocked)
        {
            <div class="alert alert-warning">@L["LockedMessage"]</div>
            @if (Model.CanUnlock)
            {
                <form method="post" asp-page-handler="Unlock" class="row g-2 mb-3 align-items-end">
                    <input type="hidden" asp-for="Id" />
                    <div class="col-md-8">
                        <label class="form-label">@L["UnlockReason"]</label>
                        <input asp-for="UnlockReason" class="form-control" required />
                    </div>
                    <div class="col-md-4">
                        <button type="submit" class="btn btn-primary">@L["UnlockForRevision"]</button>
                    </div>
                </form>
            }
            <a asp-page="./Detail" asp-route-id="@Model.Id" class="btn btn-secondary">@L["Cancel"]</a>
        }
        else
        {
            <form method="post">
                <input type="hidden" asp-for="Id" />
                <div asp-validation-summary="All" class="text-danger"></div>
                <abp-select asp-for="Order.CustomerId" asp-items="Model.CustomerOptions" label="@L["Customer"]" />
                <abp-input asp-for="Order.Status" />
                <abp-input asp-for="Order.OrderDate" />
                <abp-input asp-for="Order.PaymentTerms" />
                <abp-select asp-for="Order.CurrencyCode" asp-items="Model.CurrencyOptions" label="@L["Currency"]" />
                <abp-select asp-for="Order.WarehouseId" asp-items="Model.WarehouseOptions" label="@L["Warehouse"]" />
                @if (Model.CanUseProjects)
                {
                    <abp-select asp-for="Order.ProjectId" asp-items="Model.ProjectOptions" label="@L["Project"]" />
                }
                <abp-input asp-for="Order.Notes" />

                <div class="mt-3">
                    <button type="submit" class="btn btn-primary">@L["Save"]</button>
                    <a asp-page="./Detail" asp-route-id="@Model.Id" class="btn btn-secondary">@L["Cancel"]</a>
                </div>
            </form>
        }
    </div>
</div>
