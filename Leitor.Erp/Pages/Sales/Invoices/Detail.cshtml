@page "{id}"
@using Microsoft.AspNetCore.Mvc.Localization
@using Leitor.Erp.Localization
@using Leitor.Erp.Services.Dtos.Sales
@inject IHtmlLocalizer<ErpResource> L
@model Leitor.Erp.Pages.Sales.Invoices.DetailModel

@{
    var statusBadgeClass = Model.Invoice.PaymentStatus switch
    {
        InvoicePaymentStatus.PaidInFull => "bg-success",
        InvoicePaymentStatus.PartiallyPaid => "bg-warning text-dark",
        InvoicePaymentStatus.Overdue => "bg-danger",
        InvoicePaymentStatus.Overpaid => "bg-info text-dark",
        _ => "bg-secondary"
    };
}

<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0">
            @Model.Invoice.InvoiceNumber
            <span class="badge @statusBadgeClass ms-2">@L[$"Enum:InvoicePaymentStatus:{(int)Model.Invoice.PaymentStatus}"]</span>
        </h5>
        <div>
            <a asp-page="./Detail" asp-page-handler="Pdf" asp-route-id="@Model.Invoice.Id" class="btn btn-outline-secondary">@L["DownloadPdf"]</a>
            @if (!string.IsNullOrWhiteSpace(Model.Customer.Email))
            {
                <form method="post" asp-page-handler="Email" asp-route-id="@Model.Invoice.Id" class="d-inline" onsubmit="return confirm('@L["EmailToCustomer"]?');">
                    <button type="submit" class="btn btn-outline-secondary">@L["EmailToCustomer"]</button>
                </form>
            }
            <a asp-page="./Index" class="btn btn-secondary">@L["BackToList"]</a>
        </div>
    </div>
    <div class="card-body">
        <partial name="/Pages/Shared/_PendingDeletionBanner.cshtml" model="Model.HasPendingDeletionRequest" />
        <dl class="row mb-0">
            <dt class="col-sm-2">@L["Customer"]</dt>
            <dd class="col-sm-4">@Model.Invoice.CustomerName</dd>
            <dt class="col-sm-2">@L["Status"]</dt>
            <dd class="col-sm-4">@L[$"Enum:InvoiceStatus:{(int)Model.Invoice.Status}"]</dd>

            <dt class="col-sm-2">@L["IssueDate"]</dt>
            <dd class="col-sm-4">@Model.Invoice.IssueDate.ToShortDateString()</dd>
            <dt class="col-sm-2">@L["DueDate"]</dt>
            <dd class="col-sm-4">@Model.Invoice.DueDate.ToShortDateString()</dd>

            <dt class="col-sm-2">@L["Subtotal"]</dt>
            <dd class="col-sm-4">@Model.Invoice.Subtotal.ToString("N2")</dd>
            <dt class="col-sm-2">@L["Tax"]</dt>
            <dd class="col-sm-4">@Model.Invoice.TaxAmount.ToString("N2")</dd>

            <dt class="col-sm-2">@L["Total"]</dt>
            <dd class="col-sm-4">@Model.Invoice.Total.ToString("N2")</dd>
            <dt class="col-sm-2">@L["AmountPaid"]</dt>
            <dd class="col-sm-4">@Model.Invoice.AmountPaid.ToString("N2")</dd>

            @if (!string.IsNullOrWhiteSpace(Model.Invoice.Notes))
            {
                <dt class="col-sm-2">@L["Notes"]</dt>
                <dd class="col-sm-10">@Model.Invoice.Notes</dd>
            }
        </dl>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header">
        <h5 class="card-title mb-0">@L["Lines"]</h5>
    </div>
    <div class="card-body">
        @if (Model.CanEdit)
        {
            <form method="post" asp-page-handler="AddLine" class="row g-2 mb-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label">@L["Product"]</label>
                    <select asp-for="NewLine.ProductId" asp-items="Model.ProductOptions" class="form-select"></select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">@L["Description"]</label>
                    <input asp-for="NewLine.Description" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">@L["UnitPrice"]</label>
                    <input asp-for="NewLine.UnitPrice" class="form-control" />
                </div>
                <div class="col-md-1">
                    <label class="form-label">@L["Quantity"]</label>
                    <input asp-for="NewLine.Quantity" class="form-control" />
                </div>
                <div class="col-md-1">
                    <label class="form-label">@L["DiscountPercent"]</label>
                    <input asp-for="NewLine.DiscountPercent" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">@L["TaxRate"]</label>
                    <select asp-for="NewLine.TaxRateId" asp-items="Model.TaxRateOptions" class="form-select"></select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary">@L["AddLine"]</button>
                </div>
            </form>
        }
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>@L["Description"]</th>
                        <th>@L["UnitPrice"]</th>
                        <th>@L["Quantity"]</th>
                        <th>@L["DiscountPercent"]</th>
                        <th>@L["Tax"]</th>
                        <th>@L["LineTotal"]</th>
                        <th>@L["Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var line in Model.Lines)
                    {
                        <tr>
                            <td>@line.Description</td>
                            <td>@line.UnitPrice.ToString("N2")</td>
                            <td>@line.Quantity</td>
                            <td>@line.DiscountPercent</td>
                            <td>@line.TaxRatePercent.ToString("N0")%</td>
                            <td>@line.LineTotal.ToString("N2")</td>
                            <td>
                                @if (Model.CanEdit)
                                {
                                    <form method="post" asp-page-handler="DeleteLine" asp-route-lineId="@line.Id" onsubmit="return confirm('@L["AreYouSureToDelete"]');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">@L["Delete"]</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h5 class="card-title mb-0">@L["Payments"]</h5>
    </div>
    <div class="card-body">
        @if (Model.CanEdit)
        {
            <form method="post" asp-page-handler="AddPayment" class="row g-2 mb-3 align-items-end">
                <div class="col-md-2">
                    <label class="form-label">@L["Amount"]</label>
                    <input asp-for="NewPayment.Amount" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">@L["PaymentDate"]</label>
                    <input asp-for="NewPayment.PaymentDate" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">@L["Method"]</label>
                    <select asp-for="NewPayment.Method" class="form-select">
                        <option value="0">@L["Enum:PaymentMethod:0"]</option>
                        <option value="1">@L["Enum:PaymentMethod:1"]</option>
                        <option value="2">@L["Enum:PaymentMethod:2"]</option>
                        <option value="3">@L["Enum:PaymentMethod:3"]</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">@L["Reference"]</label>
                    <input asp-for="NewPayment.Reference" class="form-control" />
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary">@L["NewPayment"]</button>
                </div>
            </form>
        }
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>@L["PaymentDate"]</th>
                        <th>@L["Amount"]</th>
                        <th>@L["Method"]</th>
                        <th>@L["Reference"]</th>
                        <th>@L["Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var payment in Model.Payments)
                    {
                        <tr>
                            <td>@payment.PaymentDate.ToShortDateString()</td>
                            <td>@payment.Amount.ToString("N2")</td>
                            <td>@L[$"Enum:PaymentMethod:{(int)payment.Method}"]</td>
                            <td>@payment.Reference</td>
                            <td>
                                @if (Model.CanEdit)
                                {
                                    <form method="post" asp-page-handler="DeletePayment" asp-route-paymentId="@payment.Id" onsubmit="return confirm('@L["AreYouSureToDelete"]');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">@L["Delete"]</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
