@page
@using Microsoft.AspNetCore.Mvc.Localization
@using Leitor.Erp.Localization
@inject IHtmlLocalizer<ErpResource> L
@model Leitor.Erp.Pages.Sales.Invoices.CreateModel

<div class="card">
    <div class="card-header">
        <h5 class="card-title mb-0">@L["NewInvoice"]</h5>
    </div>
    <div class="card-body">
        <form method="post">
            <div asp-validation-summary="All" class="text-danger"></div>
            <abp-select asp-for="Invoice.CustomerId" asp-items="Model.CustomerOptions" label="@L["Customer"]" />
            <abp-input asp-for="Invoice.Status" />
            <abp-input asp-for="Invoice.IssueDate" />
            <abp-input asp-for="Invoice.DueDate" />
            <abp-input asp-for="Invoice.Notes" />

            <div class="mt-3">
                <button type="submit" class="btn btn-primary">@L["Save"]</button>
                <a asp-page="./Index" class="btn btn-secondary">@L["Cancel"]</a>
            </div>
        </form>
    </div>
</div>
