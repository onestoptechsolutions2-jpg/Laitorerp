@page
@using Microsoft.AspNetCore.Mvc.Localization
@using Leitor.Erp.Localization
@using Leitor.Erp.Entities.FieldService
@inject IHtmlLocalizer<ErpResource> L
@model Leitor.Erp.Pages.FieldService.Jobs.IndexModel

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0">@L["Jobs"]</h5>
        @if (Model.CanCreate)
        {
            <a asp-page="./Create" class="btn btn-primary">@L["NewJob"]</a>
        }
    </div>
    <div class="card-body">
        <form method="get" class="row g-2 mb-3">
            <div class="col-auto">
                <input type="text" class="form-control" name="Filter" value="@Model.Filter" placeholder="@L["Description"] / @L["SiteAddress"]" />
            </div>
            <div class="col-auto">
                <select name="Status" class="form-select">
                    <option value="">@L["Status"]: @L["None"]</option>
                    <option value="0" selected="@(Model.Status == FieldServiceJobStatus.Scheduled)">@L["Enum:FieldServiceJobStatus:0"]</option>
                    <option value="1" selected="@(Model.Status == FieldServiceJobStatus.InProgress)">@L["Enum:FieldServiceJobStatus:1"]</option>
                    <option value="2" selected="@(Model.Status == FieldServiceJobStatus.Completed)">@L["Enum:FieldServiceJobStatus:2"]</option>
                    <option value="3" selected="@(Model.Status == FieldServiceJobStatus.Incomplete)">@L["Enum:FieldServiceJobStatus:3"]</option>
                    <option value="4" selected="@(Model.Status == FieldServiceJobStatus.Cancelled)">@L["Enum:FieldServiceJobStatus:4"]</option>
                </select>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-secondary">@L["Search"]</button>
            </div>
        </form>
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>@L["Customer"]</th>
                        <th>@L["Type"]</th>
                        <th>@L["Status"]</th>
                        <th>@L["ScheduledDate"]</th>
                        <th>@L["AssignedTo"]</th>
                        <th>@L["Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var job in Model.Jobs)
                    {
                        <tr>
                            <td><a asp-page="./Detail" asp-route-id="@job.Id">@job.CustomerName</a></td>
                            <td>@L[$"Enum:FieldServiceJobType:{(int)job.Type}"]</td>
                            <td>@L[$"Enum:FieldServiceJobStatus:{(int)job.Status}"]</td>
                            <td>@job.ScheduledDate.ToShortDateString()</td>
                            <td>@job.AssignedToUserName</td>
                            <td>
                                @if (Model.CanDelete)
                                {
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@job.Id" class="d-inline" onsubmit="return confirm('@(Model.CanDecideDeletions ? L["AreYouSureToDelete"] : L["AreYouSureToRequestDeletion"])');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">@(Model.CanDecideDeletions ? L["Delete"] : L["RequestDeletion"])</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <partial name="/Pages/Shared/_Pagination.cshtml" model="Model.Pagination" />
    </div>
</div>
