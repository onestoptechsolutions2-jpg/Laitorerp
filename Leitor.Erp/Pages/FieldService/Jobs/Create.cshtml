@page
@using Microsoft.AspNetCore.Mvc.Localization
@using Leitor.Erp.Localization
@inject IHtmlLocalizer<ErpResource> L
@model Leitor.Erp.Pages.FieldService.Jobs.CreateModel

<div class="card">
    <div class="card-header">
        <h5 class="card-title mb-0">@L["NewJob"]</h5>
    </div>
    <div class="card-body">
        <form method="post">
            <div asp-validation-summary="All" class="text-danger"></div>
            <abp-select asp-for="Job.CustomerId" asp-items="Model.CustomerOptions" label="@L["Customer"].Value" />
            <abp-select asp-for="Job.OrderId" asp-items="Model.OrderOptions" label="@L["Order"].Value" />
            <abp-select asp-for="Job.ContractId" asp-items="Model.ContractOptions" label="@L["Contract"].Value" />
            <abp-input asp-for="Job.Type" />
            <abp-input asp-for="Job.Status" />
            <abp-input asp-for="Job.ScheduledDate" />
            <abp-select asp-for="Job.AssignedToUserId" asp-items="Model.UserOptions" label="@L["AssignedTo"].Value" />
            <abp-select asp-for="Job.VendorId" asp-items="Model.VendorOptions" label="@L["Subcontractor"].Value" />
            <abp-input asp-for="Job.SiteAddress" />
            <abp-input asp-for="Job.Description" />

            <div class="mt-3">
                <button type="submit" class="btn btn-primary">@L["Save"]</button>
                <a asp-page="./Index" class="btn btn-secondary">@L["Cancel"]</a>
            </div>
        </form>
    </div>
</div>
