@page "{id}"
@using Microsoft.AspNetCore.Mvc.Localization
@using Leitor.Erp.Localization
@inject IHtmlLocalizer<ErpResource> L
@model Leitor.Erp.Pages.AuditLogs.DetailModel

<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0">@L["AuditLogDetail"]</h5>
        <a asp-page="./Index" class="btn btn-secondary">@L["BackToList"]</a>
    </div>
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-2">@L["ExecutionTime"]</dt>
            <dd class="col-sm-4">@Model.AuditLog.ExecutionTime.ToString("yyyy-MM-dd HH:mm:ss")</dd>
            <dt class="col-sm-2">@L["User"]</dt>
            <dd class="col-sm-4">@(Model.AuditLog.UserName ?? L["None"].Value)</dd>

            <dt class="col-sm-2">@L["HttpMethod"]</dt>
            <dd class="col-sm-4">@Model.AuditLog.HttpMethod</dd>
            <dt class="col-sm-2">@L["HttpStatusCode"]</dt>
            <dd class="col-sm-4">@Model.AuditLog.HttpStatusCode</dd>

            <dt class="col-sm-2">@L["Url"]</dt>
            <dd class="col-sm-10">@Model.AuditLog.Url</dd>

            <dt class="col-sm-2">@L["ExecutionDuration"]</dt>
            <dd class="col-sm-4">@Model.AuditLog.ExecutionDuration ms</dd>
            <dt class="col-sm-2">@L["ClientIpAddress"]</dt>
            <dd class="col-sm-4">@Model.AuditLog.ClientIpAddress</dd>

            @if (!string.IsNullOrWhiteSpace(Model.AuditLog.BrowserInfo))
            {
                <dt class="col-sm-2">@L["BrowserInfo"]</dt>
                <dd class="col-sm-10">@Model.AuditLog.BrowserInfo</dd>
            }

            @if (!string.IsNullOrWhiteSpace(Model.AuditLog.Comments))
            {
                <dt class="col-sm-2">@L["Comments"]</dt>
                <dd class="col-sm-10">@Model.AuditLog.Comments</dd>
            }
        </dl>

        @if (!string.IsNullOrWhiteSpace(Model.AuditLog.Exceptions))
        {
            <hr />
            <h6>@L["Exceptions"]</h6>
            <pre class="bg-danger-subtle p-2 small">@Model.AuditLog.Exceptions</pre>
        }
    </div>
</div>

@if (Model.AuditLog.Actions.Count > 0)
{
    <div class="card mb-3">
        <div class="card-header">
            <div class="card-title mb-0">@L["Actions_Performed"]</div>
        </div>
        <div class="card-body">
            <table class="table table-sm mb-0">
                <thead>
                    <tr>
                        <th>@L["ServiceName"]</th>
                        <th>@L["MethodName"]</th>
                        <th>@L["ExecutionTime"]</th>
                        <th>@L["ExecutionDuration"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var action in Model.AuditLog.Actions)
                    {
                        <tr>
                            <td>@action.ServiceName</td>
                            <td>@action.MethodName</td>
                            <td>@action.ExecutionTime.ToString("HH:mm:ss.fff")</td>
                            <td>@action.ExecutionDuration</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (Model.AuditLog.EntityChanges.Count > 0)
{
    <div class="card">
        <div class="card-header">
            <div class="card-title mb-0">@L["EntityChanges"]</div>
        </div>
        <div class="card-body">
            @foreach (var change in Model.AuditLog.EntityChanges)
            {
                <div class="mb-3">
                    <div class="fw-bold">
                        @L[$"Enum:EntityChangeType:{(int)change.ChangeType}"] - @change.EntityTypeFullName
                        <span class="text-muted small">(@L["EntityId"]: @change.EntityId)</span>
                    </div>
                    @if (change.PropertyChanges.Count > 0)
                    {
                        <table class="table table-sm mb-0">
                            <thead>
                                <tr>
                                    <th>@L["PropertyName"]</th>
                                    <th>@L["OriginalValue"]</th>
                                    <th>@L["NewValue"]</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var property in change.PropertyChanges)
                                {
                                    <tr>
                                        <td>@property.PropertyName</td>
                                        <td>@property.OriginalValue</td>
                                        <td>@property.NewValue</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            }
        </div>
    </div>
}
