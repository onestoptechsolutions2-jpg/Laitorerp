@page
@using Microsoft.AspNetCore.Mvc.Localization
@using Leitor.Erp.Localization
@using Leitor.Erp.Pages.Governance.GuidedWorkflow
@using Leitor.Erp.Entities.Opportunities
@using Leitor.Erp.Entities.Sales
@using Leitor.Erp.Entities.FieldService
@inject IHtmlLocalizer<ErpResource> L
@model Leitor.Erp.Pages.Governance.GuidedWorkflow.IndexModel

@if (Model.OpportunityId == null)
{
    <div class="row g-3">
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header">
                    <h5 class="card-title mb-0">@L["StartNew"]</h5>
                </div>
                <div class="card-body">
                    <form method="post" asp-page-handler="CreateLeadAndOpportunity">
                        <abp-input asp-for="NewLead.Name" />
                        <abp-input asp-for="NewLead.CompanyName" />
                        <abp-input asp-for="NewLead.Email" />
                        <abp-input asp-for="NewLead.Phone" />
                        <button type="submit" class="btn btn-primary mt-2">@L["StartGuidedWorkflow"]</button>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header">
                    <h5 class="card-title mb-0">@L["ResumeExisting"]</h5>
                </div>
                <div class="card-body">
                    @if (Model.ResumableOpportunities.Count > 0)
                    {
                        <form method="post" asp-page-handler="Resume" class="mb-3">
                            <label class="form-label">@L["Opportunities"]</label>
                            <div class="input-group">
                                <select name="opportunityId" class="form-select">
                                    @foreach (var item in Model.ResumableOpportunities)
                                    {
                                        <option value="@item.Value">@item.Text</option>
                                    }
                                </select>
                                <button type="submit" class="btn btn-outline-primary">@L["ContinueWorkflow"]</button>
                            </div>
                        </form>
                    }
                    else
                    {
                        <p class="text-muted">@L["NoOpportunities"]</p>
                    }
                    @if (Model.ConvertibleLeads.Count > 0)
                    {
                        <hr />
                        <form method="post" asp-page-handler="ConvertExistingLead">
                            <label class="form-label">@L["ConvertExistingLead"]</label>
                            <div class="input-group">
                                <select name="leadId" class="form-select">
                                    @foreach (var item in Model.ConvertibleLeads)
                                    {
                                        <option value="@item.Value">@item.Text</option>
                                    }
                                </select>
                                <button type="submit" class="btn btn-outline-primary">@L["ConvertToCustomer"]</button>
                            </div>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="d-flex flex-wrap gap-2 mb-3">
        <span class="pill pill-success">@L["Opportunities"]</span>
        <span class="pill @(Model.Proposal != null ? "pill-success" : "pill-info")">@L["Proposals"]</span>
        <span class="pill @(Model.Quote != null ? "pill-success" : (Model.Proposal != null ? "pill-info" : "pill-neutral"))">@L["Quote"]</span>
        <span class="pill @(Model.Order != null ? "pill-success" : (Model.Quote != null ? "pill-info" : "pill-neutral"))">@L["Order"]</span>
        <span class="pill @(Model.CurrentStep is GuidedStep.ScheduleOrSkipInstallation or GuidedStep.InstallationInProgress or GuidedStep.ReadyForFinalInvoice or GuidedStep.Done ? "pill-success" : "pill-neutral")">@L["ConfirmOrder"]</span>
        <span class="pill @(Model.Jobs.Count > 0 || Model.CurrentStep is GuidedStep.ReadyForFinalInvoice or GuidedStep.Done ? "pill-success" : "pill-neutral")">@L["Jobs"]</span>
        <span class="pill @(Model.CurrentStep == GuidedStep.Done ? "pill-success" : "pill-neutral")">@L["Invoice"]</span>
    </div>

    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="card-title mb-0">@Model.Opportunity!.Name</h5>
            <a asp-page="/Governance/GuidedWorkflow/Index" class="btn btn-sm btn-outline-secondary">@L["StartNew"]</a>
        </div>
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-2">@L["Customer"]</dt>
                <dd class="col-sm-4"><a asp-page="/Customers/Detail" asp-route-id="@Model.Customer!.Id">@Model.Customer!.Name</a></dd>
                <dt class="col-sm-2">@L["Status"]</dt>
                <dd class="col-sm-4"><span class="pill @StatusPill.For(Model.Opportunity!.Status)">@L[$"Enum:OpportunityStatus:{(int)Model.Opportunity!.Status}"]</span></dd>

                @if (Model.Proposal != null)
                {
                    <dt class="col-sm-2">@L["Proposals"]</dt>
                    <dd class="col-sm-4">
                        <a class="doc-no" asp-page="/Opportunities/Proposals/Edit" asp-route-id="@Model.Proposal.Id" asp-route-opportunityId="@Model.Opportunity!.Id">@Model.Proposal.ProposalNumber</a>
                        <span class="pill @StatusPill.For(Model.Proposal.Status)">@L[$"Enum:ProposalStatus:{(int)Model.Proposal.Status}"]</span>
                    </dd>
                }
                @if (Model.Quote != null)
                {
                    <dt class="col-sm-2">@L["Quote"]</dt>
                    <dd class="col-sm-4">
                        <a class="doc-no" asp-page="/Sales/Quotes/Detail" asp-route-id="@Model.Quote.Id">@Model.Quote.QuoteNumber</a>
                        <span class="pill @StatusPill.For(Model.Quote.Status)">@L[$"Enum:QuoteStatus:{(int)Model.Quote.Status}"]</span>
                    </dd>
                }
                @if (Model.Order != null)
                {
                    <dt class="col-sm-2">@L["Order"]</dt>
                    <dd class="col-sm-4">
                        <a class="doc-no" asp-page="/Sales/Orders/Detail" asp-route-id="@Model.Order.Id">@Model.Order.OrderNumber</a>
                        <span class="pill @StatusPill.For(Model.Order.Status)">@L[$"Enum:OrderStatus:{(int)Model.Order.Status}"]</span>
                    </dd>
                }
            </dl>
        </div>
    </div>

    <div class="card">
        @switch (Model.CurrentStep)
        {
            case GuidedStep.NeedsProposal:
                <div class="card-header"><h5 class="card-title mb-0">@L["NewProposal"]</h5></div>
                <div class="card-body">
                    <form method="post" asp-page-handler="CreateProposal" asp-route-opportunityId="@Model.Opportunity!.Id">
                        <abp-input asp-for="NewProposal.Title" />
                        <abp-input asp-for="NewProposal.Summary" />
                        <abp-input asp-for="NewProposal.ProposedSolution" />
                        <button type="submit" class="btn btn-primary mt-2">@L["NewProposal"]</button>
                    </form>
                </div>
                break;

            case GuidedStep.ProposalDraft:
                <div class="card-header"><h5 class="card-title mb-0">@L["EmailToCustomer"]</h5></div>
                <div class="card-body">
                    <form method="post" asp-page-handler="SendProposalEmail" asp-route-opportunityId="@Model.Opportunity!.Id" asp-route-proposalId="@Model.Proposal!.Id" class="d-inline">
                        <button type="submit" class="btn btn-primary">@L["EmailToCustomer"]</button>
                    </form>
                    <form method="post" asp-page-handler="MarkProposalWhatsApp" asp-route-opportunityId="@Model.Opportunity!.Id" asp-route-proposalId="@Model.Proposal!.Id" class="d-inline" onsubmit="return confirm('@L["MarkSentWhatsAppConfirm"]');">
                        <button type="submit" class="btn btn-outline-secondary">@L["MarkSentWhatsApp"]</button>
                    </form>
                    <a asp-page="/Opportunities/Proposals/Edit" asp-route-id="@Model.Proposal!.Id" asp-route-opportunityId="@Model.Opportunity!.Id" class="btn btn-outline-secondary">@L["Edit"]</a>
                </div>
                break;

            case GuidedStep.ProposalSent:
                <div class="card-header"><h5 class="card-title mb-0">@L["ConvertToQuote"]</h5></div>
                <div class="card-body">
                    <form method="post" asp-page-handler="ConvertProposalToQuote" asp-route-opportunityId="@Model.Opportunity!.Id" asp-route-proposalId="@Model.Proposal!.Id" onsubmit="return confirm('@L["ConvertToQuote"]?');">
                        <button type="submit" class="btn btn-success">@L["ConvertToQuote"]</button>
                    </form>
                </div>
                break;

            case GuidedStep.ProposalRejected:
                <div class="card-body">
                    <p class="text-muted mb-2">@L["ProposalRejectedHint"]</p>
                    <a asp-page="/Opportunities/Proposals/Edit" asp-route-id="@Model.Proposal!.Id" asp-route-opportunityId="@Model.Opportunity!.Id" class="btn btn-outline-secondary">@L["Edit"]</a>
                </div>
                break;

            case GuidedStep.QuoteDraft:
                <div class="card-header"><h5 class="card-title mb-0">@L["EmailToCustomer"]</h5></div>
                <div class="card-body">
                    <form method="post" asp-page-handler="SendQuoteEmail" asp-route-opportunityId="@Model.Opportunity!.Id" asp-route-quoteId="@Model.Quote!.Id">
                        <button type="submit" class="btn btn-primary">@L["EmailToCustomer"]</button>
                    </form>
                </div>
                break;

            case GuidedStep.QuoteSent:
                <div class="card-header"><h5 class="card-title mb-0">@L["ConvertToOrder"]</h5></div>
                <div class="card-body">
                    <form method="post" asp-page-handler="ConvertQuoteToOrder" asp-route-opportunityId="@Model.Opportunity!.Id" asp-route-quoteId="@Model.Quote!.Id" onsubmit="return confirm('@L["ConvertToOrder"]?');">
                        <button type="submit" class="btn btn-success">@L["ConvertToOrder"]</button>
                    </form>
                </div>
                break;

            case GuidedStep.QuoteDeadEnd:
                <div class="card-body">
                    <p class="text-muted mb-2">@L["QuoteDeadEndHint"]</p>
                    <a asp-page="/Sales/Quotes/Edit" asp-route-id="@Model.Quote!.Id" class="btn btn-outline-secondary">@L["Edit"]</a>
                </div>
                break;

            case GuidedStep.OrderSubmitted:
                <div class="card-header"><h5 class="card-title mb-0">@L["ConfirmOrder"]</h5></div>
                <div class="card-body">
                    <form method="post" asp-page-handler="ConfirmOrder" asp-route-opportunityId="@Model.Opportunity!.Id" asp-route-orderId="@Model.Order!.Id" onsubmit="return confirm('@L["ConfirmOrder"]?');">
                        <button type="submit" class="btn btn-success">@L["ConfirmOrder"]</button>
                    </form>
                </div>
                break;

            case GuidedStep.ScheduleOrSkipInstallation:
                <div class="card-header"><h5 class="card-title mb-0">@L["ScheduleInstallation"]</h5></div>
                <div class="card-body">
                    <form method="post" asp-page-handler="ScheduleInstallation" asp-route-opportunityId="@Model.Opportunity!.Id" asp-route-orderId="@Model.Order!.Id" class="mb-3">
                        <abp-input asp-for="NewJob.ScheduledDate" />
                        <abp-select asp-for="NewJob.AssignedToUserId" asp-items="Model.UserOptions" label="@L["AssignedTo"]" />
                        <abp-select asp-for="NewJob.VendorId" asp-items="Model.VendorOptions" label="@L["Vendor"]" />
                        <abp-input asp-for="NewJob.Description" />
                        <button type="submit" class="btn btn-primary mt-2">@L["ScheduleInstallation"]</button>
                    </form>
                    <form method="post" asp-page-handler="IssueFinalInvoice" asp-route-opportunityId="@Model.Opportunity!.Id" asp-route-orderId="@Model.Order!.Id" onsubmit="return confirm('@L["IssueFinalInvoice"]?');">
                        <button type="submit" class="btn btn-link px-0">@L["SkipInstallation"]</button>
                    </form>
                </div>
                break;

            case GuidedStep.InstallationInProgress:
                <div class="card-header"><h5 class="card-title mb-0">@L["Jobs"]</h5></div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-striped">
                            <thead>
                                <tr>
                                    <th>@L["ScheduledDate"]</th>
                                    <th>@L["Status"]</th>
                                    <th>@L["Actions"]</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var job in Model.Jobs)
                                {
                                    <tr>
                                        <td>@job.ScheduledDate.ToShortDateString()</td>
                                        <td><span class="pill @StatusPill.For(job.Status)">@L[$"Enum:FieldServiceJobStatus:{(int)job.Status}"]</span></td>
                                        <td>
                                            @if (job.Status != FieldServiceJobStatus.Completed)
                                            {
                                                <form method="post" asp-page-handler="CompleteInstallation" asp-route-opportunityId="@Model.Opportunity!.Id" asp-route-jobId="@job.Id">
                                                    <button type="submit" class="btn btn-sm btn-success">@L["MarkInstallationComplete"]</button>
                                                </form>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                break;

            case GuidedStep.ReadyForFinalInvoice:
                <div class="card-header"><h5 class="card-title mb-0">@L["IssueFinalInvoice"]</h5></div>
                <div class="card-body">
                    <form method="post" asp-page-handler="IssueFinalInvoice" asp-route-opportunityId="@Model.Opportunity!.Id" asp-route-orderId="@Model.Order!.Id" onsubmit="return confirm('@L["IssueFinalInvoice"]?');">
                        <button type="submit" class="btn btn-success">@L["IssueFinalInvoice"]</button>
                    </form>
                </div>
                break;

            case GuidedStep.Done:
                <div class="card-header"><h5 class="card-title mb-0">@L["WorkflowComplete"]</h5></div>
                <div class="card-body">
                    <p>@L["WorkflowCompleteHint"]</p>
                    @if (Model.Opportunity!.Status != OpportunityStatus.Won)
                    {
                        <form method="post" asp-page-handler="CloseWon" asp-route-opportunityId="@Model.Opportunity!.Id" class="d-inline">
                            <button type="submit" class="btn btn-success">@L["CloseAsWon"]</button>
                        </form>
                    }
                    <a asp-page="/Governance/WorkflowMonitor/Index" class="btn btn-outline-secondary">@L["WorkflowMonitor"]</a>
                    <a asp-page="/Governance/GuidedWorkflow/Index" class="btn btn-outline-secondary">@L["StartNew"]</a>
                </div>
                break;
        }
    </div>
}
