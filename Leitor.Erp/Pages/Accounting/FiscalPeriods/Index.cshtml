@page
@using Microsoft.AspNetCore.Mvc.Localization
@using Leitor.Erp.Localization
@inject IHtmlLocalizer<ErpResource> L
@model Leitor.Erp.Pages.Accounting.FiscalPeriods.IndexModel

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0">@L["FiscalPeriods"]</h5>
        @if (Model.CanManage)
        {
            <form method="post" asp-page-handler="CloseYear" onsubmit="return confirm('@L["ConfirmCloseYear"]');">
                <input type="hidden" name="Year" value="@Model.Year" />
                <button type="submit" class="btn btn-danger">@L["CloseYear"]</button>
            </form>
        }
    </div>
    <div class="card-body">
        <form method="get" class="row g-2 mb-3">
            <div class="col-auto">
                <label class="form-label">@L["FiscalYear"]</label>
                <input type="number" name="Year" class="form-control" value="@Model.Year" />
            </div>
            <div class="col-auto align-self-end">
                <button type="submit" class="btn btn-secondary">@L["Search"]</button>
            </div>
        </form>

        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>@L["Month"]</th>
                        <th>@L["Status"]</th>
                        <th>@L["Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.Grid.Months)
                    {
                        <tr>
                            <td>@System.Globalization.CultureInfo.InvariantCulture.DateTimeFormat.GetMonthName(row.Month)</td>
                            <td>
                                <span class="pill @(row.IsLocked ? "pill-danger" : "pill-success")">
                                    @(row.IsLocked ? L["Locked"] : L["Open"])
                                </span>
                            </td>
                            <td>
                                @if (Model.CanManage)
                                {
                                    <form method="post" asp-page-handler="Toggle" class="d-inline">
                                        <input type="hidden" name="month" value="@row.Month" />
                                        <input type="hidden" name="locked" value="@(!row.IsLocked)" />
                                        <button type="submit" class="btn btn-sm @(row.IsLocked ? "btn-outline-success" : "btn-outline-danger")">
                                            @(row.IsLocked ? L["Unlock"] : L["Lock"])
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
