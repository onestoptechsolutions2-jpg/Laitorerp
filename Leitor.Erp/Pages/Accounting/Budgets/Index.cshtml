@page
@using Microsoft.AspNetCore.Mvc.Localization
@using Leitor.Erp.Localization
@inject IHtmlLocalizer<ErpResource> L
@model Leitor.Erp.Pages.Accounting.Budgets.IndexModel

@{
    var months = new[] { "Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec" };
    var cellIndex = 0;
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0">@L["Budgets"]</h5>
        <a asp-page="/Accounting/Reports/BudgetVariance/Index" asp-route-FiscalYear="@Model.FiscalYear" class="btn btn-outline-secondary">@L["BudgetVariance"]</a>
    </div>
    <div class="card-body">
        <form method="get" class="row g-2 mb-3">
            <div class="col-auto">
                <label class="form-label">@L["FiscalYear"]</label>
                <input type="number" name="FiscalYear" class="form-control" value="@Model.FiscalYear" />
            </div>
            <div class="col-auto align-self-end">
                <button type="submit" class="btn btn-secondary">@L["Search"]</button>
            </div>
        </form>

        <form method="post">
            <input type="hidden" asp-for="Save.FiscalYear" value="@Model.FiscalYear" />
            <div class="table-responsive">
                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>@L["Account"]</th>
                            @foreach (var m in months)
                            {
                                <th>@m</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Grid.Rows.Any())
                        {
                            <tr class="table-empty-state"><td colspan="13">@L["NoResultsFound"]</td></tr>
                        }
                        @foreach (var row in Model.Grid.Rows)
                        {
                            <tr>
                                <td>@row.AccountCode - @row.AccountName</td>
                                @for (var m = 0; m < 12; m++)
                                {
                                    var i = cellIndex++;
                                    <td>
                                        @if (Model.CanEdit)
                                        {
                                            <input type="hidden" name="Save.Cells[@i].AccountId" value="@row.AccountId" />
                                            <input type="hidden" name="Save.Cells[@i].Month" value="@(m + 1)" />
                                            <input type="number" step="0.01" name="Save.Cells[@i].Amount" value="@row.MonthAmounts[m]" class="form-control form-control-sm" style="min-width: 5.5rem;" />
                                        }
                                        else
                                        {
                                            @row.MonthAmounts[m].ToString("N0")
                                        }
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (Model.CanEdit && Model.Grid.Rows.Any())
            {
                <button type="submit" class="btn btn-primary">@L["Save"]</button>
            }
        </form>
    </div>
</div>
