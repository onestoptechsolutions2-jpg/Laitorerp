@page "{id}"
@using Microsoft.AspNetCore.Mvc.Localization
@using Leitor.Erp.Localization
@inject IHtmlLocalizer<ErpResource> L
@model Leitor.Erp.Pages.Accounting.BankAccounts.EditModel

<div class="card">
    <div class="card-header">
        <h5 class="card-title mb-0">@L["EditBankAccount"]</h5>
    </div>
    <div class="card-body">
        <form method="post">
            <div asp-validation-summary="All" class="text-danger"></div>
            <abp-input asp-for="BankAccount.Name" />
            <abp-input asp-for="BankAccount.BankName" />
            <abp-input asp-for="BankAccount.AccountNumber" />
            <abp-select asp-for="BankAccount.CurrencyCode" asp-items="Model.CurrencyOptions" label="@L["Currency"].Value" />
            <abp-select asp-for="BankAccount.LinkedGlAccountId" asp-items="Model.AccountOptions" label="@L["LinkedGlAccount"].Value" />
            <abp-input asp-for="BankAccount.OpeningBalance" />
            <abp-input asp-for="BankAccount.OpeningBalanceDate" />

            <div class="mt-3">
                <button type="submit" class="btn btn-primary">@L["Save"]</button>
                <a asp-page="./Index" class="btn btn-secondary">@L["Cancel"]</a>
            </div>
        </form>
    </div>
</div>
