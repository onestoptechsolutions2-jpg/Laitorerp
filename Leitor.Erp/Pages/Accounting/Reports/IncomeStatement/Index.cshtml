@page
@using Microsoft.AspNetCore.Mvc.Localization
@using Leitor.Erp.Localization
@inject IHtmlLocalizer<ErpResource> L
@model Leitor.Erp.Pages.Accounting.Reports.IncomeStatement.IndexModel

<div class="card">
    <div class="card-header">
        <h5 class="card-title mb-0">@L["IncomeStatement"]</h5>
    </div>
    <div class="card-body">
        <form method="get" class="row g-2 mb-3">
            <div class="col-auto">
                <label class="form-label">@L["FromDate"]</label>
                <input type="date" name="FromDate" class="form-control" value="@Model.FromDate.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-auto">
                <label class="form-label">@L["ToDate"]</label>
                <input type="date" name="ToDate" class="form-control" value="@Model.ToDate.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-auto align-self-end">
                <button type="submit" class="btn btn-secondary">@L["Search"]</button>
            </div>
        </form>

        <h6>@L["Revenue"]</h6>
        <div class="table-responsive mb-3">
            <table class="table table-sm table-striped">
                <tbody>
                    @if (!Model.Report.RevenueLines.Any())
                    {
                        <tr class="table-empty-state"><td colspan="2">@L["NoResultsFound"]</td></tr>
                    }
                    @foreach (var line in Model.Report.RevenueLines)
                    {
                        <tr>
                            <td>@line.AccountCode - @line.AccountName</td>
                            <td class="text-end">@line.Amount.ToString("N2")</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <th>@L["TotalRevenue"]</th>
                        <th class="text-end">@Model.Report.TotalRevenue.ToString("N2")</th>
                    </tr>
                </tfoot>
            </table>
        </div>

        <h6>@L["Expenses"]</h6>
        <div class="table-responsive mb-3">
            <table class="table table-sm table-striped">
                <tbody>
                    @if (!Model.Report.ExpenseLines.Any())
                    {
                        <tr class="table-empty-state"><td colspan="2">@L["NoResultsFound"]</td></tr>
                    }
                    @foreach (var line in Model.Report.ExpenseLines)
                    {
                        <tr>
                            <td>@line.AccountCode - @line.AccountName</td>
                            <td class="text-end">@line.Amount.ToString("N2")</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <th>@L["TotalExpenses"]</th>
                        <th class="text-end">@Model.Report.TotalExpense.ToString("N2")</th>
                    </tr>
                </tfoot>
            </table>
        </div>

        <div class="d-flex justify-content-between border-top pt-2">
            <strong>@L["NetIncome"]</strong>
            <strong>@Model.Report.NetIncome.ToString("N2")</strong>
        </div>
    </div>
</div>
