@page
@using Microsoft.AspNetCore.Mvc.Localization
@using Leitor.Erp.Localization
@inject IHtmlLocalizer<ErpResource> L
@model Leitor.Erp.Pages.Accounting.ChartOfAccounts.IndexModel

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0">@L["ChartOfAccounts"]</h5>
        <div>
            @if (Model.CanEdit)
            {
                <a asp-page="./Create" class="btn btn-primary">@L["NewAccount"]</a>
            }
        </div>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>@L["AccountCode"]</th>
                        <th>@L["Name"]</th>
                        <th>@L["AccountType"]</th>
                        <th>@L["SystemRole"]</th>
                        <th>@L["Active"]</th>
                        <th>@L["Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Accounts.Any())
                    {
                        <tr class="table-empty-state"><td colspan="6">@L["NoResultsFound"]</td></tr>
                    }
                    @foreach (var account in Model.Accounts)
                    {
                        <tr>
                            <td>@account.Code</td>
                            <td>@account.Name</td>
                            <td>@L[$"Enum:AccountType:{(int)account.Type}"]</td>
                            <td>@L[$"Enum:SystemAccountRole:{(int)account.SystemRole}"]</td>
                            <td>@(account.IsActive ? "✓" : "")</td>
                            <td>
                                @if (Model.CanEdit)
                                {
                                    <a asp-page="./Edit" asp-route-id="@account.Id" class="btn btn-sm btn-outline-primary">@L["Edit"]</a>
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@account.Id" class="d-inline" onsubmit="return confirm('@L["AreYouSureToDelete"]');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">@L["Delete"]</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
