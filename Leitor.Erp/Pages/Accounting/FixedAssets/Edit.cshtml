@page "{id}"
@using Microsoft.AspNetCore.Mvc.Localization
@using Leitor.Erp.Localization
@inject IHtmlLocalizer<ErpResource> L
@model Leitor.Erp.Pages.Accounting.FixedAssets.EditModel

<div class="card">
    <div class="card-header">
        <h5 class="card-title mb-0">@L["EditFixedAsset"]</h5>
    </div>
    <div class="card-body">
        <form method="post">
            <div asp-validation-summary="All" class="text-danger"></div>
            <abp-input asp-for="Asset.Name" />
            <abp-input asp-for="Asset.Category" />
            <abp-input asp-for="Asset.PurchaseDate" />
            <abp-input asp-for="Asset.PurchaseCost" />
            <abp-input asp-for="Asset.SalvageValue" />
            <abp-input asp-for="Asset.UsefulLifeMonths" />
            <abp-input asp-for="Asset.Status" />
            <abp-select asp-for="Asset.AssetAccountId" asp-items="Model.AccountOptions" label="@L["AssetAccount"].Value" />
            <abp-select asp-for="Asset.DepreciationExpenseAccountId" asp-items="Model.AccountOptions" label="@L["DepreciationExpenseAccount"].Value" />
            <abp-select asp-for="Asset.AccumulatedDepreciationAccountId" asp-items="Model.AccountOptions" label="@L["AccumulatedDepreciationAccount"].Value" />

            <div class="mt-3">
                <button type="submit" class="btn btn-primary">@L["Save"]</button>
                <a asp-page="./Index" class="btn btn-secondary">@L["Cancel"]</a>
            </div>
        </form>
    </div>
</div>
