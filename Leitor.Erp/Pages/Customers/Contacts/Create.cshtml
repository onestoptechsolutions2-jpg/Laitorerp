@page "{customerId}"
@using Microsoft.AspNetCore.Mvc.Localization
@using Leitor.Erp.Localization
@inject IHtmlLocalizer<ErpResource> L
@model Leitor.Erp.Pages.Customers.Contacts.CreateModel

<div class="card">
    <div class="card-header">
        <h5 class="card-title mb-0">@L["NewContact"]</h5>
    </div>
    <div class="card-body">
        <form method="post">
            <input type="hidden" asp-for="Contact.CustomerId" value="@Model.CustomerId" />
            <div asp-validation-summary="All" class="text-danger"></div>
            <abp-input asp-for="Contact.FullName" />
            <abp-input asp-for="Contact.JobTitle" />
            <abp-input asp-for="Contact.Email" />
            <abp-input asp-for="Contact.PhoneNumber" />
            <abp-input asp-for="Contact.IsPrimary" />
            <abp-input asp-for="Contact.Notes" />

            <div class="mt-3">
                <button type="submit" class="btn btn-primary">@L["Save"]</button>
                <a asp-page="/Customers/Detail" asp-route-id="@Model.CustomerId" class="btn btn-secondary">@L["Cancel"]</a>
            </div>
        </form>
    </div>
</div>
