@page "{id}"
@using Microsoft.AspNetCore.Mvc.Localization
@using Leitor.Erp.Localization
@inject IHtmlLocalizer<ErpResource> L
@model Leitor.Erp.Pages.Customers.DetailModel

<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0">@Model.Customer.Name</h5>
        <div>
            @if (Model.CanEdit)
            {
                <a asp-page="./Edit" asp-route-id="@Model.Customer.Id" class="btn btn-outline-primary">@L["Edit"]</a>
            }
            <a asp-page="./Index" class="btn btn-secondary">@L["BackToList"]</a>
        </div>
    </div>
    <div class="card-body">
        <partial name="/Pages/Shared/_PendingDeletionBanner.cshtml" model="Model.HasPendingDeletionRequest" />
        <dl class="row mb-0">
            <dt class="col-sm-2">@L["Email"]</dt>
            <dd class="col-sm-4">@Model.Customer.Email</dd>
            <dt class="col-sm-2">@L["PhoneNumber"]</dt>
            <dd class="col-sm-4">@Model.Customer.PhoneNumber</dd>

            <dt class="col-sm-2">@L["Status"]</dt>
            <dd class="col-sm-4"><span class="pill @StatusPill.For(Model.Customer.Status)">@L[$"Enum:CustomerStatus:{(int)Model.Customer.Status}"]</span></dd>
            <dt class="col-sm-2">@L["Country"]</dt>
            <dd class="col-sm-4">@Model.Customer.Country</dd>

            <dt class="col-sm-2">@L["AccountOwner"]</dt>
            <dd class="col-sm-10">@(Model.Customer.AccountOwnerUserName ?? L["None"].Value)</dd>

            @if (!string.IsNullOrWhiteSpace(Model.Customer.PortalUserName))
            {
                <dt class="col-sm-2">@L["PortalAccess"]</dt>
                <dd class="col-sm-10">@Model.Customer.PortalUserName</dd>
            }

            <dt class="col-sm-2">@L["AddressLine"]</dt>
            <dd class="col-sm-10">
                @Model.Customer.AddressLine, @Model.Customer.City @Model.Customer.State @Model.Customer.PostalCode
            </dd>

            @if (!string.IsNullOrWhiteSpace(Model.Customer.Notes))
            {
                <dt class="col-sm-2">@L["Notes"]</dt>
                <dd class="col-sm-10">@Model.Customer.Notes</dd>
            }
        </dl>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header">
        <h5 class="card-title mb-0">@L["PipelineAndFinance"]</h5>
    </div>
    <div class="card-body">
        <div class="row mb-3">
            <div class="col-xl-2 col-lg-3 col-md-4 col-sm-6 d-flex mb-3">
                <div class="card w-100 kpi-card">
                    <div class="card-body">
                        <div class="kpi-icon"><i class="fas fa-sack-dollar"></i></div>
                        <div class="kpi-body">
                            <div class="text-muted small">@L["LifetimeRevenue"]</div>
                            <div class="h4 mb-0">@Model.LifetimeRevenue.ToString("N2")</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-xl-2 col-lg-3 col-md-4 col-sm-6 d-flex mb-3">
                <div class="card w-100 kpi-card">
                    <div class="card-body">
                        <div class="kpi-icon"><i class="fas fa-hand-holding-dollar"></i></div>
                        <div class="kpi-body">
                            <div class="text-muted small">@L["OutstandingBalance"]</div>
                            <div class="h4 mb-0">@Model.OutstandingBalance.ToString("N2")</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-xl-2 col-lg-3 col-md-4 col-sm-6 d-flex mb-3">
                <div class="card w-100 kpi-card">
                    <div class="card-body">
                        <div class="kpi-icon"><i class="fas fa-file-invoice-dollar"></i></div>
                        <div class="kpi-body">
                            <div class="text-muted small">@L["TotalOrders"]</div>
                            <div class="h4 mb-0">@Model.TotalOrders</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-xl-2 col-lg-3 col-md-4 col-sm-6 d-flex mb-3">
                <div class="card w-100 kpi-card">
                    <div class="card-body">
                        <div class="kpi-icon"><i class="fas fa-bullseye"></i></div>
                        <div class="kpi-body">
                            <div class="text-muted small">@L["OpenOpportunities"]</div>
                            <div class="h4 mb-0">@Model.OpenOpportunities</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-xl-2 col-lg-3 col-md-4 col-sm-6 d-flex mb-3">
                <div class="card w-100 kpi-card">
                    <div class="card-body">
                        <div class="kpi-icon"><i class="fas fa-percent"></i></div>
                        <div class="kpi-body">
                            <div class="text-muted small">@L["WinRate"]</div>
                            <div class="h4 mb-0">@(Model.WinRate.HasValue ? (Model.WinRate.Value * 100).ToString("N0") + "%" : "-")</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-xl-2 col-lg-3 col-md-4 col-sm-6 d-flex mb-3">
                <div class="card w-100 kpi-card">
                    <div class="card-body">
                        <div class="kpi-icon"><i class="fas fa-scale-balanced"></i></div>
                        <div class="kpi-body">
                            <div class="text-muted small">@L["AverageDealSize"]</div>
                            <div class="h4 mb-0">@(Model.AverageDealSize.HasValue ? Model.AverageDealSize.Value.ToString("N2") : "-")</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @if (Model.OriginatingLead != null)
        {
            <dl class="row mb-3">
                <dt class="col-sm-2">@L["FromLead"]</dt>
                <dd class="col-sm-10">@Model.OriginatingLead.Name (@L[$"Enum:LeadSource:{(int)Model.OriginatingLead.Source}"])</dd>
            </dl>
        }

        <h6>@L["Opportunities"]</h6>
        @if (Model.Opportunities.Count == 0)
        {
            <p class="text-muted small">@L["NoneYet"]</p>
        }
        else
        {
            <div class="table-responsive mb-3">
                <table class="table table-sm table-striped">
                    <thead><tr><th>@L["Name"]</th><th>@L["Status"]</th><th>@L["EstimatedValue"]</th></tr></thead>
                    <tbody>
                        @foreach (var opportunity in Model.Opportunities)
                        {
                            <tr>
                                <td><a asp-page="/Opportunities/Detail" asp-route-id="@opportunity.Id">@opportunity.Name</a></td>
                                <td><span class="pill @StatusPill.For(opportunity.Status)">@L[$"Enum:OpportunityStatus:{(int)opportunity.Status}"]</span></td>
                                <td>@opportunity.EstimatedValue?.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        <h6>@L["Proposals"]</h6>
        @if (Model.Proposals.Count == 0)
        {
            <p class="text-muted small">@L["NoneYet"]</p>
        }
        else
        {
            <div class="table-responsive mb-3">
                <table class="table table-sm table-striped">
                    <thead><tr><th>@L["ProposalNumber"]</th><th>@L["Title"]</th><th>@L["Status"]</th></tr></thead>
                    <tbody>
                        @foreach (var proposal in Model.Proposals)
                        {
                            <tr>
                                <td><a class="doc-no" asp-page="/Opportunities/Proposals/Edit" asp-route-id="@proposal.Id" asp-route-opportunityId="@proposal.OpportunityId">@proposal.ProposalNumber</a></td>
                                <td>@proposal.Title</td>
                                <td><span class="pill @StatusPill.For(proposal.Status)">@L[$"Enum:ProposalStatus:{(int)proposal.Status}"]</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        <h6>@L["Quotes"]</h6>
        @if (Model.Quotes.Count == 0)
        {
            <p class="text-muted small">@L["NoneYet"]</p>
        }
        else
        {
            <div class="table-responsive mb-3">
                <table class="table table-sm table-striped">
                    <thead><tr><th>@L["QuoteNumber"]</th><th>@L["Status"]</th><th>@L["Total"]</th></tr></thead>
                    <tbody>
                        @foreach (var quote in Model.Quotes)
                        {
                            <tr>
                                <td><a class="doc-no" asp-page="/Sales/Quotes/Detail" asp-route-id="@quote.Id">@quote.QuoteNumber</a></td>
                                <td><span class="pill @StatusPill.For(quote.Status)">@L[$"Enum:QuoteStatus:{(int)quote.Status}"]</span></td>
                                <td>@quote.Total.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        <h6>@L["Orders"]</h6>
        @if (Model.Orders.Count == 0)
        {
            <p class="text-muted small">@L["NoneYet"]</p>
        }
        else
        {
            <div class="table-responsive mb-3">
                <table class="table table-sm table-striped">
                    <thead><tr><th>@L["OrderNumber"]</th><th>@L["Status"]</th><th>@L["Total"]</th></tr></thead>
                    <tbody>
                        @foreach (var order in Model.Orders)
                        {
                            <tr>
                                <td><a class="doc-no" asp-page="/Sales/Orders/Detail" asp-route-id="@order.Id">@order.OrderNumber</a></td>
                                <td><span class="pill @StatusPill.For(order.Status)">@L[$"Enum:OrderStatus:{(int)order.Status}"]</span></td>
                                <td>@order.Total.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        <h6>@L["Invoices"]</h6>
        @if (Model.Invoices.Count == 0)
        {
            <p class="text-muted small mb-0">@L["NoneYet"]</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm table-striped mb-0">
                    <thead><tr><th>@L["InvoiceNumber"]</th><th>@L["PaymentStatus"]</th><th>@L["Total"]</th><th>@L["AmountPaid"]</th></tr></thead>
                    <tbody>
                        @foreach (var invoice in Model.Invoices)
                        {
                            <tr>
                                <td><a class="doc-no" asp-page="/Sales/Invoices/Detail" asp-route-id="@invoice.Id">@invoice.InvoiceNumber</a></td>
                                <td><span class="pill @StatusPill.For(invoice.PaymentStatus)">@L[$"Enum:InvoicePaymentStatus:{(int)invoice.PaymentStatus}"]</span></td>
                                <td>@invoice.Total.ToString("N2")</td>
                                <td>@invoice.AmountPaid.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0">@L["Contacts"]</h5>
        <a asp-page="/Customers/Contacts/Create" asp-route-customerId="@Model.Customer.Id" class="btn btn-primary btn-sm">@L["NewContact"]</a>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>@L["FullName"]</th>
                        <th>@L["JobTitle"]</th>
                        <th>@L["Email"]</th>
                        <th>@L["PhoneNumber"]</th>
                        <th>@L["IsPrimary"]</th>
                        <th>@L["Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var contact in Model.Contacts)
                    {
                        <tr>
                            <td>@contact.FullName</td>
                            <td>@contact.JobTitle</td>
                            <td>@contact.Email</td>
                            <td>@contact.PhoneNumber</td>
                            <td>@(contact.IsPrimary ? "✓" : "")</td>
                            <td>
                                <a asp-page="/Customers/Contacts/Edit" asp-route-id="@contact.Id" asp-route-customerId="@Model.Customer.Id" class="btn btn-sm btn-outline-primary">@L["Edit"]</a>
                                <form method="post" asp-page-handler="DeleteContact" asp-route-contactId="@contact.Id" class="d-inline" onsubmit="return confirm('@L["AreYouSureToDelete"]');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">@L["Delete"]</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0">@L["Contracts"]</h5>
        <a asp-page="/Customers/Contracts/Create" asp-route-customerId="@Model.Customer.Id" class="btn btn-primary btn-sm">@L["NewContract"]</a>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>@L["ContractNumber"]</th>
                        <th>@L["Title"]</th>
                        <th>@L["Type"]</th>
                        <th>@L["Status"]</th>
                        <th>@L["StartDate"]</th>
                        <th>@L["EndDate"]</th>
                        <th>@L["Value"]</th>
                        <th>@L["Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var contract in Model.Contracts)
                    {
                        <tr>
                            <td>@contract.ContractNumber</td>
                            <td>@contract.Title</td>
                            <td>@L[$"Enum:CustomerContractType:{(int)contract.Type}"]</td>
                            <td>@L[$"Enum:CustomerContractStatus:{(int)contract.Status}"]</td>
                            <td>@contract.StartDate.ToShortDateString()</td>
                            <td>@(contract.EndDate?.ToShortDateString())</td>
                            <td>@contract.Value</td>
                            <td>
                                <a asp-page="/Customers/Contracts/Edit" asp-route-id="@contract.Id" asp-route-customerId="@Model.Customer.Id" class="btn btn-sm btn-outline-primary">@L["Edit"]</a>
                                <form method="post" asp-page-handler="DeleteContract" asp-route-contractId="@contract.Id" class="d-inline" onsubmit="return confirm('@L["AreYouSureToDelete"]');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">@L["Delete"]</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0">@L["Tasks"]</h5>
        <a asp-page="/Customers/Tasks/Create" asp-route-customerId="@Model.Customer.Id" class="btn btn-primary btn-sm">@L["NewTask"]</a>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>@L["Title"]</th>
                        <th>@L["DueDate"]</th>
                        <th>@L["AssignedTo"]</th>
                        <th>@L["IsCompleted"]</th>
                        <th>@L["Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var task in Model.TaskItems)
                    {
                        <tr class="@(task.IsCompleted ? "text-decoration-line-through text-muted" : "")">
                            <td>@task.Title</td>
                            <td>@(task.DueDate?.ToShortDateString())</td>
                            <td>@task.AssignedToUserName</td>
                            <td>@(task.IsCompleted ? "✓" : "")</td>
                            <td>
                                <form method="post" asp-page-handler="ToggleTask" asp-route-taskId="@task.Id" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-outline-secondary">@(task.IsCompleted ? L["Reopen"] : L["MarkComplete"])</button>
                                </form>
                                <a asp-page="/Customers/Tasks/Edit" asp-route-id="@task.Id" asp-route-customerId="@Model.Customer.Id" class="btn btn-sm btn-outline-primary">@L["Edit"]</a>
                                <form method="post" asp-page-handler="DeleteTask" asp-route-taskId="@task.Id" class="d-inline" onsubmit="return confirm('@L["AreYouSureToDelete"]');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">@L["Delete"]</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0">@L["Documents"]</h5>
        <a asp-page="/Customers/Attachments/Upload" asp-route-customerId="@Model.Customer.Id" class="btn btn-primary btn-sm">@L["UploadDocument"]</a>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>@L["FileName"]</th>
                        <th>@L["FileSize"]</th>
                        <th>@L["UploadedBy"]</th>
                        <th>@L["Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var attachment in Model.Attachments)
                    {
                        <tr>
                            <td>@attachment.FileName</td>
                            <td>@((attachment.FileSizeBytes / 1024.0).ToString("N0")) KB</td>
                            <td>@attachment.UploadedByUserName</td>
                            <td>
                                <a asp-page="/Customers/Attachments/Download" asp-route-id="@attachment.Id" class="btn btn-sm btn-outline-primary">@L["Download"]</a>
                                <form method="post" asp-page-handler="DeleteAttachment" asp-route-attachmentId="@attachment.Id" class="d-inline" onsubmit="return confirm('@L["AreYouSureToDelete"]');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">@L["Delete"]</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h5 class="card-title mb-0">@L["Activity"]</h5>
    </div>
    <div class="card-body">
        <form method="post" asp-page-handler="AddNote" class="row g-2 mb-3">
            <div class="col-auto">
                <select asp-for="NewNote.Type" class="form-select">
                    <option value="0">@L["Enum:CustomerNoteType:0"]</option>
                    <option value="1">@L["Enum:CustomerNoteType:1"]</option>
                    <option value="2">@L["Enum:CustomerNoteType:2"]</option>
                    <option value="3">@L["Enum:CustomerNoteType:3"]</option>
                </select>
            </div>
            <div class="col">
                <input type="text" asp-for="NewNote.Text" class="form-control" placeholder="@L["NoteText"]" />
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-primary">@L["AddNote"]</button>
            </div>
        </form>

        @foreach (var note in Model.Notes)
        {
            <div class="border-bottom pb-2 mb-2">
                <div class="d-flex justify-content-between">
                    <div>
                        <span class="badge bg-secondary">@L[$"Enum:CustomerNoteType:{(int)note.Type}"]</span>
                        <strong class="ms-2">@note.CreatorUserName</strong>
                        <span class="text-muted ms-2">@note.CreationTime.ToString("g")</span>
                    </div>
                    <form method="post" asp-page-handler="DeleteNote" asp-route-noteId="@note.Id" onsubmit="return confirm('@L["AreYouSureToDelete"]');">
                        <button type="submit" class="btn btn-sm btn-outline-danger">@L["Delete"]</button>
                    </form>
                </div>
                <div>@note.Text</div>
            </div>
        }
    </div>
</div>

<div class="card mt-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0">@L["FieldServiceJobs"]</h5>
        <a asp-page="/FieldService/Jobs/Create" class="btn btn-primary btn-sm">@L["NewJob"]</a>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>@L["Type"]</th>
                        <th>@L["Status"]</th>
                        <th>@L["ScheduledDate"]</th>
                        <th>@L["AssignedTo"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var job in Model.FieldServiceJobs)
                    {
                        <tr>
                            <td><a asp-page="/FieldService/Jobs/Detail" asp-route-id="@job.Id">@L[$"Enum:FieldServiceJobType:{(int)job.Type}"]</a></td>
                            <td><span class="pill @StatusPill.For(job.Status)">@L[$"Enum:FieldServiceJobStatus:{(int)job.Status}"]</span></td>
                            <td>@job.ScheduledDate.ToShortDateString()</td>
                            <td>@job.AssignedToUserName</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="card mt-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0">@L["Tickets"]</h5>
        <div>
            <a asp-page="/Support/WarrantyClaims/Create" asp-route-customerId="@Model.Customer.Id" class="btn btn-outline-primary btn-sm">@L["NewWarrantyClaim"]</a>
            <a asp-page="/Support/Tickets/Create" class="btn btn-primary btn-sm">@L["NewTicket"]</a>
        </div>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>@L["TicketNumber"]</th>
                        <th>@L["Subject"]</th>
                        <th>@L["Status"]</th>
                        <th>@L["Priority"]</th>
                        <th>@L["AssignedTo"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ticket in Model.Tickets)
                    {
                        <tr>
                            <td><a class="doc-no" asp-page="/Support/Tickets/Detail" asp-route-id="@ticket.Id">@ticket.TicketNumber</a></td>
                            <td>@ticket.Subject</td>
                            <td><span class="pill @StatusPill.For(ticket.Status)">@L[$"Enum:TicketStatus:{(int)ticket.Status}"]</span></td>
                            <td>@L[$"Enum:TicketPriority:{(int)ticket.Priority}"]</td>
                            <td>@ticket.AssignedToUserName</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
