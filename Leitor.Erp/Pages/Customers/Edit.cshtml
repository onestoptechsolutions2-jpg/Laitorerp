@page
@using Microsoft.AspNetCore.Mvc.Localization
@using Leitor.Erp.Localization
@inject IHtmlLocalizer<ErpResource> L
@model Leitor.Erp.Pages.Customers.EditModel

<div class="card">
    <div class="card-header">
        <h5 class="card-title mb-0">@L["EditCustomer"]</h5>
    </div>
    <div class="card-body">
        <form method="post">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="All" class="text-danger"></div>
            <abp-input asp-for="Customer.Name" />
            <abp-input asp-for="Customer.Email" />
            <abp-input asp-for="Customer.PhoneNumber" />
            <abp-input asp-for="Customer.Status" />
            <abp-select asp-for="Customer.AccountOwnerUserId" asp-items="Model.UserOptions" label="@L["AccountOwner"]" />
            <abp-input asp-for="Customer.AddressLine" />
            <abp-input asp-for="Customer.City" />
            <abp-input asp-for="Customer.State" />
            <abp-input asp-for="Customer.PostalCode" />
            <abp-input asp-for="Customer.Country" />
            <abp-input asp-for="Customer.Notes" />

            <div class="mt-3">
                <button type="submit" class="btn btn-primary">@L["Save"]</button>
                <a asp-page="./Detail" asp-route-id="@Model.Id" class="btn btn-secondary">@L["Cancel"]</a>
            </div>
        </form>
    </div>
</div>
