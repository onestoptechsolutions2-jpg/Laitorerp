@page "{id}/{customerId}"
@using Microsoft.AspNetCore.Mvc.Localization
@using Leitor.Erp.Localization
@inject IHtmlLocalizer<ErpResource> L
@model Leitor.Erp.Pages.Customers.Contracts.EditModel

<div class="card">
    <div class="card-header">
        <h5 class="card-title mb-0">@L["EditContract"]</h5>
    </div>
    <div class="card-body">
        <form method="post">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CustomerId" />
            <div asp-validation-summary="All" class="text-danger"></div>
            <abp-input asp-for="Contract.ContractNumber" />
            <abp-input asp-for="Contract.Title" />
            <abp-input asp-for="Contract.Type" />
            <abp-input asp-for="Contract.Status" />
            <abp-input asp-for="Contract.StartDate" />
            <abp-input asp-for="Contract.EndDate" />
            <abp-input asp-for="Contract.Value" />
            <abp-input asp-for="Contract.Notes" />

            <div class="mt-3">
                <button type="submit" class="btn btn-primary">@L["Save"]</button>
                <a asp-page="/Customers/Detail" asp-route-id="@Model.CustomerId" class="btn btn-secondary">@L["Cancel"]</a>
            </div>
        </form>
    </div>
</div>
