@page
@using Microsoft.AspNetCore.Mvc.Localization
@using Leitor.Erp.Localization
@inject IHtmlLocalizer<ErpResource> L
@model Leitor.Erp.Pages.ServiceCatalog.CreateModel

<div class="card">
    <div class="card-header">
        <h5 class="card-title mb-0">@L["NewServiceCatalogItem"]</h5>
    </div>
    <div class="card-body">
        <form method="post">
            <div asp-validation-summary="All" class="text-danger"></div>
            <abp-input asp-for="Item.Name" />
            <abp-input asp-for="Item.Description" />
            <abp-input asp-for="Item.Category" />
            <abp-select asp-for="Item.OwnerUserId" asp-items="Model.UserOptions" label="@L["Owner"].Value" />
            <abp-input asp-for="Item.TargetSlaHours" />
            <abp-input asp-for="Item.IsActive" />

            <div class="mt-3">
                <button type="submit" class="btn btn-primary">@L["Save"]</button>
                <a asp-page="./Index" class="btn btn-secondary">@L["Cancel"]</a>
            </div>
        </form>
    </div>
</div>
