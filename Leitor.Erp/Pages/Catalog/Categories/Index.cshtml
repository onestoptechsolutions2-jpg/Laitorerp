@page
@using Microsoft.AspNetCore.Mvc.Localization
@using Leitor.Erp.Localization
@inject IHtmlLocalizer<ErpResource> L
@model Leitor.Erp.Pages.Catalog.Categories.IndexModel

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0">@L["Categories"]</h5>
        <div>
            <a asp-page="../Index" class="btn btn-outline-secondary">@L["BackToCatalog"]</a>
            @if (Model.CanEdit)
            {
                <a asp-page="./Create" class="btn btn-primary">@L["NewCategory"]</a>
            }
        </div>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>@L["Name"]</th>
                        <th>@L["Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Categories.Any())
                    {
                        <tr class="table-empty-state"><td colspan="2">@L["NoResultsFound"]</td></tr>
                    }
                    @foreach (var category in Model.Categories)
                    {
                        <tr>
                            <td>@category.Name</td>
                            <td>
                                @if (Model.CanEdit)
                                {
                                    <a asp-page="./Edit" asp-route-id="@category.Id" class="btn btn-sm btn-outline-primary">@L["Edit"]</a>
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@category.Id" class="d-inline" onsubmit="return confirm('@L["AreYouSureToDelete"]');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">@L["Delete"]</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
