@page "{id}"
@using Microsoft.AspNetCore.Mvc.Localization
@using Leitor.Erp.Localization
@inject IHtmlLocalizer<ErpResource> L
@model Leitor.Erp.Pages.Catalog.PriceLists.DetailModel

<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0">@Model.PriceList.Name</h5>
        <a asp-page="./Index" class="btn btn-secondary">@L["BackToList"]</a>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h5 class="card-title mb-0">@L["Products"]</h5>
    </div>
    <div class="card-body">
        @if (Model.CanEdit)
        {
            <form method="post" asp-page-handler="AddItem" class="row g-2 mb-3 align-items-end">
                <div class="col-md-6">
                    <label class="form-label">@L["Product"]</label>
                    <select asp-for="NewItem.ProductId" asp-items="Model.ProductOptions" class="form-select"></select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">@L["UnitPrice"]</label>
                    <input asp-for="NewItem.UnitPrice" class="form-control" />
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary">@L["AddPrice"]</button>
                </div>
            </form>
        }
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>@L["Product"]</th>
                        <th>@L["UnitPrice"]</th>
                        <th>@L["Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Items.Any())
                    {
                        <tr class="table-empty-state"><td colspan="3">@L["NoResultsFound"]</td></tr>
                    }
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.ProductName</td>
                            <td>@item.UnitPrice.ToString("N2")</td>
                            <td>
                                @if (Model.CanEdit)
                                {
                                    <form method="post" asp-page-handler="DeleteItem" asp-route-itemId="@item.Id" onsubmit="return confirm('@L["AreYouSureToDelete"]');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">@L["Delete"]</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
