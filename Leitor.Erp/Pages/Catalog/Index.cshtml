@page
@using Microsoft.AspNetCore.Mvc.Localization
@using Leitor.Erp.Localization
@inject IHtmlLocalizer<ErpResource> L
@model Leitor.Erp.Pages.Catalog.IndexModel

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0">@L["Products"]</h5>
        <div>
            <a asp-page="./Categories/Index" class="btn btn-outline-secondary">@L["Categories"]</a>
            <a asp-page="./PriceLists/Index" class="btn btn-outline-secondary">@L["PriceLists"]</a>
            <a asp-page="./TaxRates/Index" class="btn btn-outline-secondary">@L["TaxRates"]</a>
            @if (Model.CanCreate)
            {
                <a asp-page="./Create" class="btn btn-primary">@L["NewProduct"]</a>
            }
        </div>
    </div>
    <div class="card-body">
        <form method="get" class="row g-2 mb-3">
            <div class="col-auto">
                <input type="text" class="form-control" name="Filter" value="@Model.Filter" placeholder="@L["Name"]" />
            </div>
            <div class="col-auto">
                <select name="CategoryId" class="form-select" onchange="this.form.submit()">
                    @foreach (var item in Model.CategoryOptions)
                    {
                        <option value="@item.Value" selected="@(item.Value == (Model.CategoryId.HasValue ? Model.CategoryId.ToString() : ""))">@item.Text</option>
                    }
                </select>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-secondary">@L["Search"]</button>
            </div>
        </form>
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>@L["Name"]</th>
                        <th>@L["Sku"]</th>
                        <th>@L["Category"]</th>
                        <th>@L["Type"]</th>
                        <th>@L["UnitPrice"]</th>
                        <th>@L["IsActive"]</th>
                        <th>@L["Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Products.Any())
                    {
                        <tr class="table-empty-state"><td colspan="7">@L["NoResultsFound"]</td></tr>
                    }
                    @foreach (var product in Model.Products)
                    {
                        <tr>
                            <td><a asp-page="./Detail" asp-route-id="@product.Id">@product.Name</a></td>
                            <td>@product.Sku</td>
                            <td>@product.CategoryName</td>
                            <td>@L[$"Enum:ProductType:{(int)product.Type}"]</td>
                            <td>@product.UnitPrice.ToString("N2")</td>
                            <td><span class="pill @(product.IsActive ? "pill-success" : "pill-neutral")">@(product.IsActive ? L["Active"] : L["Inactive"])</span></td>
                            <td>
                                @if (Model.CanEdit)
                                {
                                    <a asp-page="./Edit" asp-route-id="@product.Id" class="btn btn-sm btn-outline-primary">@L["Edit"]</a>
                                }
                                @if (Model.CanDelete)
                                {
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@product.Id" asp-route-Filter="@Model.Filter" class="d-inline" onsubmit="return confirm('@L["AreYouSureToDelete"]');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">@L["Delete"]</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <partial name="/Pages/Shared/_Pagination.cshtml" model="Model.Pagination" />
    </div>
</div>
