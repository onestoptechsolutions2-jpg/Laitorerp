@page
@using Microsoft.AspNetCore.Mvc.Localization
@using Leitor.Erp.Localization
@inject IHtmlLocalizer<ErpResource> L
@model Leitor.Erp.Pages.Catalog.EditModel

<div class="card">
    <div class="card-header">
        <h5 class="card-title mb-0">@L["EditProduct"]</h5>
    </div>
    <div class="card-body">
        <form method="post">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="All" class="text-danger"></div>
            <abp-input asp-for="Product.Name" />
            <abp-input asp-for="Product.Sku" />
            <abp-input asp-for="Product.Type" />
            <abp-input asp-for="Product.UnitPrice" />
            <abp-input asp-for="Product.Cost" />
            <div class="mb-3">
                <label class="form-label">@L["TaxRate"]</label>
                <select asp-for="Product.TaxRateId" asp-items="Model.TaxRateOptions" class="form-select">
                    <option value="">@L["UseDefaultTaxRate"]</option>
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label">@L["Category"]</label>
                <select asp-for="Product.CategoryId" asp-items="Model.CategoryOptions" class="form-select">
                    <option value="">@L["None"]</option>
                </select>
            </div>
            <abp-input asp-for="Product.Description" />
            <abp-input asp-for="Product.IsActive" />
            <abp-input asp-for="Product.IsBundle" />
            <abp-input asp-for="Product.TrackInventory" />
            <abp-input asp-for="Product.ReorderPoint" />
            <abp-input asp-for="Product.ReorderQuantity" />

            <div class="mt-3">
                <button type="submit" class="btn btn-primary">@L["Save"]</button>
                <a asp-page="./Index" class="btn btn-secondary">@L["Cancel"]</a>
            </div>
        </form>
    </div>
</div>
