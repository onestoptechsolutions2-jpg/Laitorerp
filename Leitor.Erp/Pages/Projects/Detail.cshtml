@page "{id}"
@using Microsoft.AspNetCore.Mvc.Localization
@using Leitor.Erp.Localization
@inject IHtmlLocalizer<ErpResource> L
@model Leitor.Erp.Pages.Projects.DetailModel

<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0"><span class="doc-no">@Model.Project.ProjectNumber</span> - @Model.Project.Title</h5>
        <div>
            @if (Model.CanEdit)
            {
                <a asp-page="./Edit" asp-route-id="@Model.Project.Id" class="btn btn-outline-primary">@L["Edit"]</a>
            }
            <a asp-page="./Index" class="btn btn-secondary">@L["BackToList"]</a>
        </div>
    </div>
    <div class="card-body">
        <partial name="/Pages/Shared/_PendingDeletionBanner.cshtml" model="Model.HasPendingDeletionRequest" />
        <dl class="row mb-0">
            <dt class="col-sm-2">@L["Customer"]</dt>
            <dd class="col-sm-4"><a asp-page="/Customers/Detail" asp-route-id="@Model.Project.CustomerId">@Model.Project.CustomerName</a></dd>
            <dt class="col-sm-2">@L["Status"]</dt>
            <dd class="col-sm-4"><span class="pill @StatusPill.For(Model.Project.Status)">@L[$"Enum:ProjectStatus:{(int)Model.Project.Status}"]</span></dd>

            <dt class="col-sm-2">@L["StartDate"]</dt>
            <dd class="col-sm-4">@Model.Project.StartDate.ToShortDateString()</dd>
            <dt class="col-sm-2">@L["EndDate"]</dt>
            <dd class="col-sm-4">@(Model.Project.EndDate?.ToShortDateString())</dd>

            @if (Model.Project.Budget.HasValue)
            {
                <dt class="col-sm-2">@L["Budget"]</dt>
                <dd class="col-sm-4">@Model.Project.Budget.Value.ToString("N2")</dd>
            }

            @if (!string.IsNullOrWhiteSpace(Model.Project.Description))
            {
                <dt class="col-sm-2">@L["Description"]</dt>
                <dd class="col-sm-10">@Model.Project.Description</dd>
            }
        </dl>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header">
        <h5 class="card-title mb-0">@L["ProjectPnL"]</h5>
    </div>
    <div class="card-body">
        @if (Model.PnL.RevenueLines.Count == 0 && Model.PnL.ExpenseLines.Count == 0)
        {
            <p class="text-muted mb-0">@L["NoneYet"]</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm mb-0">
                    <thead>
                        <tr><th>@L["Account"]</th><th>@L["Amount"]</th></tr>
                    </thead>
                    <tbody>
                        <tr class="table-active"><td colspan="2"><strong>@L["Revenue"]</strong></td></tr>
                        @foreach (var line in Model.PnL.RevenueLines)
                        {
                            <tr><td>@line.AccountCode - @line.AccountName</td><td>@line.Amount.ToString("N2")</td></tr>
                        }
                        <tr class="table-active"><td colspan="2"><strong>@L["Expenses"]</strong></td></tr>
                        @foreach (var line in Model.PnL.ExpenseLines)
                        {
                            <tr><td>@line.AccountCode - @line.AccountName</td><td>@line.Amount.ToString("N2")</td></tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr><th>@L["NetProfit"]</th><th>@Model.PnL.NetProfit.ToString("N2")</th></tr>
                    </tfoot>
                </table>
            </div>
        }
    </div>
</div>

<div class="card mb-3">
    <div class="card-header">
        <h5 class="card-title mb-0">@L["Orders"]</h5>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-sm mb-0">
                <thead>
                    <tr><th>@L["OrderNumber"]</th><th>@L["Status"]</th><th>@L["Total"]</th></tr>
                </thead>
                <tbody>
                    @if (!Model.Orders.Any())
                    {
                        <tr class="table-empty-state"><td colspan="3">@L["NoResultsFound"]</td></tr>
                    }
                    @foreach (var order in Model.Orders)
                    {
                        <tr>
                            <td><a class="doc-no" asp-page="/Sales/Orders/Detail" asp-route-id="@order.Id">@order.OrderNumber</a></td>
                            <td><span class="pill @StatusPill.For(order.Status)">@L[$"Enum:OrderStatus:{(int)order.Status}"]</span></td>
                            <td>@order.Total.ToString("N2")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h5 class="card-title mb-0">@L["Tasks"]</h5>
    </div>
    <div class="card-body">
        @if (Model.CanEdit)
        {
            <form method="post" asp-page-handler="AddTask" class="row g-2 mb-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label">@L["Title"]</label>
                    <input asp-for="NewTask.Title" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">@L["DueDate"]</label>
                    <input asp-for="NewTask.DueDate" type="date" class="form-control" />
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary">@L["AddTask"]</button>
                </div>
            </form>
        }
        <div class="table-responsive">
            <table class="table table-sm mb-0">
                <thead>
                    <tr><th>@L["Title"]</th><th>@L["DueDate"]</th><th>@L["Status"]</th><th>@L["Actions"]</th></tr>
                </thead>
                <tbody>
                    @if (!Model.Tasks.Any())
                    {
                        <tr class="table-empty-state"><td colspan="4">@L["NoResultsFound"]</td></tr>
                    }
                    @foreach (var task in Model.Tasks)
                    {
                        <tr>
                            <td>@task.Title</td>
                            <td>@(task.DueDate?.ToShortDateString())</td>
                            <td><span class="pill @(task.IsCompleted ? "pill-success" : "pill-neutral")">@(task.IsCompleted ? L["Completed"] : L["Open"])</span></td>
                            <td>
                                @if (Model.CanEdit)
                                {
                                    <form method="post" asp-page-handler="ToggleTask" asp-route-taskId="@task.Id" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-outline-secondary">@(task.IsCompleted ? L["Reopen"] : L["MarkComplete"])</button>
                                    </form>
                                    <form method="post" asp-page-handler="DeleteTask" asp-route-taskId="@task.Id" class="d-inline" onsubmit="return confirm('@L["AreYouSureToDelete"]');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">@L["Delete"]</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
