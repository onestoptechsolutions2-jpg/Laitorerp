@page
@using Microsoft.AspNetCore.Mvc.Localization
@using Leitor.Erp.Localization
@inject IHtmlLocalizer<ErpResource> L
@model Leitor.Erp.Pages.Projects.IndexModel

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0">@L["Projects"]</h5>
        @if (Model.CanCreate)
        {
            <a asp-page="./Create" class="btn btn-primary">@L["NewProject"]</a>
        }
    </div>
    <div class="card-body">
        <form method="get" class="row g-2 mb-3">
            <div class="col-auto">
                <input type="text" class="form-control" name="Filter" value="@Model.Filter" placeholder="@L["Title"]" />
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-secondary">@L["Search"]</button>
            </div>
        </form>
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>@L["ProjectNumber"]</th>
                        <th>@L["Title"]</th>
                        <th>@L["Customer"]</th>
                        <th>@L["Status"]</th>
                        <th>@L["StartDate"]</th>
                        <th>@L["Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Projects.Any())
                    {
                        <tr class="table-empty-state"><td colspan="6">@L["NoResultsFound"]</td></tr>
                    }
                    @foreach (var project in Model.Projects)
                    {
                        <tr>
                            <td><a class="doc-no" asp-page="./Detail" asp-route-id="@project.Id">@project.ProjectNumber</a></td>
                            <td>@project.Title</td>
                            <td>@project.CustomerName</td>
                            <td><span class="pill @StatusPill.For(project.Status)">@L[$"Enum:ProjectStatus:{(int)project.Status}"]</span></td>
                            <td>@project.StartDate.ToShortDateString()</td>
                            <td>
                                @if (Model.CanDelete)
                                {
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@project.Id" asp-route-Filter="@Model.Filter" class="d-inline" onsubmit="return confirm('@(Model.CanDecideDeletions ? L["AreYouSureToDelete"] : L["AreYouSureToRequestDeletion"])');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">@(Model.CanDecideDeletions ? L["Delete"] : L["RequestDeletion"])</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <partial name="/Pages/Shared/_Pagination.cshtml" model="Model.Pagination" />
    </div>
</div>
