@page
@using Microsoft.AspNetCore.Mvc.Localization
@using Leitor.Erp.Localization
@inject IHtmlLocalizer<ErpResource> L
@model Leitor.Erp.Pages.IndexModel

@{
    var noModulesVisible = Model.Dashboard.Leads == null &&
                            Model.Dashboard.Customers == null &&
                            Model.Dashboard.Opportunities == null &&
                            Model.Dashboard.FieldService == null &&
                            Model.Dashboard.Sales == null;
}

@if (noModulesVisible)
{
    <div class="card">
        <div class="card-body">
            <p class="text-muted mb-0">@L["Dashboard:NoAccess"]</p>
        </div>
    </div>
}
else
{
    <div class="row mb-3">
        @if (Model.Dashboard.Leads != null)
        {
            <div class="col-xl-3 col-md-6 d-flex mb-3 mb-xl-0">
                <div class="card w-100">
                    <div class="card-body">
                        <div class="text-muted">@L["Leads"]</div>
                        <div class="display-6">@Model.Dashboard.Leads.NewCount</div>
                        <span class="small text-muted">
                            @Model.Dashboard.Leads.TouchesThisWeek @L["Dashboard:TouchesThisWeek"]
                            (@Model.Dashboard.Leads.ReplyRate.ToString("N0")% @L["Dashboard:ReplyRate"])
                        </span>
                        <a asp-page="/Leads/Index" class="small d-block">@L["Dashboard:ViewAll"]</a>
                    </div>
                </div>
            </div>
        }
        @if (Model.Dashboard.Customers != null)
        {
            <div class="col-xl-3 col-md-6 d-flex mb-3 mb-xl-0">
                <div class="card w-100">
                    <div class="card-body">
                        <div class="text-muted">@L["Customers"]</div>
                        <div class="display-6">@Model.Dashboard.Customers.TotalCount</div>
                        <a asp-page="/Customers/Index" class="small">@L["Dashboard:ViewAll"]</a>
                    </div>
                </div>
            </div>
        }
        @if (Model.Dashboard.Opportunities != null)
        {
            <div class="col-xl-3 col-md-6 d-flex mb-3 mb-xl-0">
                <div class="card w-100">
                    <div class="card-body">
                        <div class="text-muted">@L["Opportunities"]</div>
                        <div class="display-6">@Model.Dashboard.Opportunities.OpenCount</div>
                        <span class="small text-muted">
                            @Model.Dashboard.Opportunities.OpenPipelineValue.ToString("N0") @L["Dashboard:OpenPipelineValue"]
                            (@Model.Dashboard.Opportunities.WinRate.ToString("N0")% @L["Dashboard:WinRate"])
                        </span>
                        <a asp-page="/Opportunities/Index" class="small d-block">@L["Dashboard:ViewAll"]</a>
                    </div>
                </div>
            </div>
        }
        @if (Model.Dashboard.FieldService != null)
        {
            <div class="col-xl-3 col-md-6 d-flex mb-3 mb-xl-0">
                <div class="card w-100">
                    <div class="card-body">
                        <div class="text-muted">@L["Dashboard:OpenJobs"]</div>
                        <div class="display-6">@(Model.Dashboard.FieldService.ScheduledCount + Model.Dashboard.FieldService.InProgressCount)</div>
                        <a asp-page="/FieldService/Jobs/Index" class="small">@L["Dashboard:ViewAll"]</a>
                    </div>
                </div>
            </div>
        }
        @if (Model.Dashboard.Sales != null)
        {
            <div class="col-xl-3 col-md-6 d-flex mb-3 mb-xl-0">
                <div class="card w-100">
                    <div class="card-body">
                        <div class="text-muted">@L["Dashboard:OpenQuotesAndOrders"]</div>
                        <div class="display-6">@(Model.Dashboard.Sales.OpenQuoteCount + Model.Dashboard.Sales.PendingOrderCount)</div>
                        <a asp-page="/Sales/Quotes/Index" class="small">@L["Dashboard:ViewAll"]</a>
                    </div>
                </div>
            </div>
        }
        @if (Model.Dashboard.Sales != null)
        {
            <div class="col-xl-3 col-md-6 d-flex mb-3 mb-xl-0">
                <div class="card w-100">
                    <div class="card-body">
                        <div class="text-muted">@L["Dashboard:OutstandingBalance"]</div>
                        <div class="display-6">@Model.Dashboard.Sales.OutstandingAmount.ToString("N2")</div>
                        <span class="small text-muted">
                            @Model.Dashboard.Sales.UnpaidInvoiceCount @L["Dashboard:UnpaidInvoices"]
                            (@Model.Dashboard.Sales.OverdueInvoiceCount @L["Dashboard:Overdue"])
                        </span>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="row">
        @if (Model.Dashboard.FieldService != null)
        {
            <div class="col-xl-4 d-flex mb-3">
                <div class="card w-100">
                    <div class="card-header">
                        <div class="card-title text-body">@L["Dashboard:UpcomingJobs"]</div>
                    </div>
                    <div class="card-body pt-0">
                        @if (Model.Dashboard.FieldService.Upcoming.Count == 0)
                        {
                            <p class="text-muted mb-0">@L["Dashboard:NoUpcomingJobs"]</p>
                        }
                        else
                        {
                            <table class="table table-sm mb-0">
                                <tbody>
                                    @foreach (var job in Model.Dashboard.FieldService.Upcoming)
                                    {
                                        <tr>
                                            <td>
                                                <a asp-page="/FieldService/Jobs/Detail" asp-route-id="@job.Id">@job.CustomerName</a>
                                                <div class="small text-muted">@L[$"Enum:FieldServiceJobType:{(int)job.Type}"]</div>
                                            </td>
                                            <td class="text-end">
                                                @job.ScheduledDate.ToShortDateString()
                                                <div class="small text-muted">@L[$"Enum:FieldServiceJobStatus:{(int)job.Status}"]</div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    </div>
                </div>
            </div>
        }
        @if (Model.Dashboard.Sales != null)
        {
            <div class="col-xl-4 d-flex mb-3">
                <div class="card w-100">
                    <div class="card-header">
                        <div class="card-title text-body">@L["Dashboard:OverdueInvoices"]</div>
                    </div>
                    <div class="card-body pt-0">
                        @if (Model.Dashboard.Sales.OverdueInvoices.Count == 0)
                        {
                            <p class="text-muted mb-0">@L["Dashboard:NoOverdueInvoices"]</p>
                        }
                        else
                        {
                            <table class="table table-sm mb-0">
                                <tbody>
                                    @foreach (var invoice in Model.Dashboard.Sales.OverdueInvoices)
                                    {
                                        <tr>
                                            <td>
                                                <a asp-page="/Sales/Invoices/Detail" asp-route-id="@invoice.Id">@invoice.InvoiceNumber</a>
                                                <div class="small text-muted">@invoice.CustomerName</div>
                                            </td>
                                            <td class="text-end">
                                                @invoice.AmountDue.ToString("N2")
                                                <div class="small text-muted">@L["DueDate"]: @invoice.DueDate.ToShortDateString()</div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    </div>
                </div>
            </div>
        }
        @if (Model.Dashboard.Customers != null)
        {
            <div class="col-xl-4 d-flex mb-3">
                <div class="card w-100">
                    <div class="card-header">
                        <div class="card-title text-body">@L["Dashboard:RecentCustomers"]</div>
                    </div>
                    <div class="card-body pt-0">
                        @if (Model.Dashboard.Customers.Recent.Count == 0)
                        {
                            <p class="text-muted mb-0">@L["Dashboard:NoRecentCustomers"]</p>
                        }
                        else
                        {
                            <table class="table table-sm mb-0">
                                <tbody>
                                    @foreach (var customer in Model.Dashboard.Customers.Recent)
                                    {
                                        <tr>
                                            <td><a asp-page="/Customers/Detail" asp-route-id="@customer.Id">@customer.Name</a></td>
                                            <td class="text-end small text-muted">@customer.CreationTime.ToShortDateString()</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
